<!-- views/cartoes/fatura.erb - Detalhes da fatura -->

<div class="flex items-center gap-3 mb-6">
  <a href="/cartoes" class="p-2 text-slate-400 hover:text-slate-600 transition">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  </a>
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Fatura <%= nome_mes(@fatura[:mes_referencia]) %>/<%= @fatura[:ano_referencia] %></h1>
    <p class="text-slate-500 text-sm"><%= @cartao[:banco] %> •••<%= @cartao[:ultimos_digitos] %> · <%= @cartao[:apelido] %></p>
  </div>
  <% if @fatura[:status] != 'paga' %>
    <form action="/cartoes/<%= @cartao[:id] %>/faturas/<%= @fatura[:id] %>/pagar" method="POST" class="ml-auto" onsubmit="return confirm('Marcar esta fatura como PAGA? Todas as despesas pendentes serão marcadas como pagas.')">
      <input type="hidden" name="data_pagamento" value="<%= Date.today %>">
      <button type="submit" class="px-5 py-2.5 bg-emerald-600 text-white rounded-lg text-sm font-medium hover:bg-emerald-700 transition flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Pagar Fatura Inteira
      </button>
    </form>
  <% else %>
    <span class="ml-auto px-4 py-2 bg-emerald-100 text-emerald-700 rounded-lg text-sm font-semibold">✓ Fatura Paga</span>
  <% end %>
</div>

<!-- Info da Fatura -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-5 mb-8">
  <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-200">
    <span class="text-xs font-semibold text-slate-500 uppercase">Valor Total</span>
    <p class="text-2xl font-bold text-orange-600 mt-1"><%= fmt_moeda(@fatura[:valor_total]) %></p>
  </div>
  <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-200">
    <span class="text-xs font-semibold text-slate-500 uppercase">Valor Pago</span>
    <p class="text-2xl font-bold text-emerald-600 mt-1"><%= fmt_moeda(@fatura[:valor_pago]) %></p>
  </div>
  <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-200">
    <span class="text-xs font-semibold text-slate-500 uppercase">Fechamento</span>
    <p class="text-2xl font-bold text-slate-800 mt-1"><%= fmt_data(@fatura[:data_fechamento]) %></p>
  </div>
  <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-200">
    <span class="text-xs font-semibold text-slate-500 uppercase">Vencimento</span>
    <p class="text-2xl font-bold text-red-600 mt-1"><%= fmt_data(@fatura[:data_vencimento]) %></p>
  </div>
</div>

<!-- Despesas da Fatura -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200">
  <div class="px-5 py-4 border-b border-slate-100">
    <h2 class="font-semibold text-slate-800">Despesas desta Fatura</h2>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50">
          <th class="px-5 py-3">Data</th>
          <th class="px-5 py-3">Descrição</th>
          <th class="px-5 py-3">Parcelas</th>
          <th class="px-5 py-3 text-right">Valor Parcela</th>
          <th class="px-5 py-3 text-right">Valor Total</th>
          <th class="px-5 py-3">Status</th>
          <th class="px-5 py-3 text-center">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @despesas.each do |d| %>
          <tr class="hover:bg-slate-50" id="row-<%= d[:id] %>">
            <td class="px-5 py-3 text-slate-600"><%= fmt_data(d[:data_compra]) %></td>
            <td class="px-5 py-3 font-medium text-slate-800"><%= d[:descricao] %></td>
            <td class="px-5 py-3 text-slate-600">
              <% if d[:total_parcelas] > 1 %>
                <span class="px-2 py-0.5 bg-purple-100 text-purple-700 rounded-full text-xs font-medium"><%= d[:parcela_atual] %>/<%= d[:total_parcelas] %></span>
              <% else %>
                <span class="text-xs text-slate-400">À vista</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-right font-bold text-orange-600"><%= fmt_moeda(d[:valor_parcela]) %></td>
            <td class="px-5 py-3 text-right text-slate-600"><%= fmt_moeda(d[:valor_total]) %></td>
            <td class="px-5 py-3"><%= badge_status(d[:status]) %></td>
            <td class="px-5 py-3 text-center">
              <div class="flex items-center justify-center gap-1">
                <button onclick="abrirEdicao(<%= d[:id] %>, '<%= d[:descricao].gsub("'", "\\\\'") %>', '<%= fmt_valor_input(d[:valor_parcela]) %>', '<%= fmt_valor_input(d[:valor_total]) %>')" class="p-1.5 text-slate-400 hover:text-indigo-600 transition" title="Editar">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                </button>
                <form action="/cartoes/<%= @cartao[:id] %>/despesas/<%= d[:id] %>" method="POST" class="inline" onsubmit="return confirm('Tem certeza que deseja excluir esta despesa?')">
                  <input type="hidden" name="_method" value="DELETE">
                  <button type="submit" class="p-1.5 text-slate-400 hover:text-red-600 transition" title="Excluir">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @despesas.empty? %>
      <div class="text-center py-12">
        <p class="text-slate-400 text-sm">Nenhuma despesa nesta fatura</p>
      </div>
    <% end %>
  </div>
</div>

<!-- Modal de Edição -->
<div id="modal-editar" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center">
  <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-bold text-slate-800">Editar Despesa</h3>
      <button onclick="fecharEdicao()" class="text-slate-400 hover:text-slate-600">&times;</button>
    </div>
    <form id="form-editar" method="POST" class="space-y-4">
      <input type="hidden" name="_method" value="PUT">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Descrição</label>
        <input type="text" name="descricao" id="edit-descricao" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Valor da Parcela</label>
          <input type="text" name="valor_parcela" id="edit-valor-parcela" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm moeda-br">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Valor Total</label>
          <input type="text" name="valor_total" id="edit-valor-total" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm moeda-br">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Status</label>
        <select name="status" id="edit-status" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
          <option value="pendente">Pendente</option>
          <option value="paga">Paga</option>
          <option value="cancelada">Cancelada</option>
        </select>
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="fecharEdicao()" class="px-4 py-2 text-slate-600 bg-white border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50">Cancelar</button>
        <button type="submit" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">Salvar</button>
      </div>
    </form>
  </div>
</div>

<script>
function abrirEdicao(id, descricao, valorParcela, valorTotal) {
  document.getElementById('form-editar').action = '/cartoes/<%= @cartao[:id] %>/despesas/' + id;
  document.getElementById('edit-descricao').value = descricao;
  document.getElementById('edit-valor-parcela').value = valorParcela;
  document.getElementById('edit-valor-total').value = valorTotal;
  document.getElementById('modal-editar').classList.remove('hidden');
}

function fecharEdicao() {
  document.getElementById('modal-editar').classList.add('hidden');
}

// Fechar modal clicando fora
document.getElementById('modal-editar').addEventListener('click', function(e) {
  if (e.target === this) fecharEdicao();
});
</script>
