<!-- views/usuarios/form.erb - Novo usuário -->

<div class="max-w-xl mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <a href="/usuarios" class="p-2 text-slate-400 hover:text-slate-600 transition">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h1 class="text-2xl font-bold text-slate-800">Novo Usuário</h1>
  </div>

  <form action="/usuarios" method="POST" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 space-y-4">
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Nome Completo *</label>
      <input type="text" name="nome" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Email *</label>
      <input type="email" name="email" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Senha *</label>
      <input type="password" name="senha" required minlength="6" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Nível de Acesso *</label>
      <select name="nivel_acesso" required class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
        <% FinSystem::Config::ACCESS_LEVELS.each do |key, val| %>
          <option value="<%= key %>"><%= val[:label] %></option>
        <% end %>
      </select>
      <p class="text-xs text-slate-400 mt-1">
        Admin: acesso total · Gerente: empresas e financeiro · Financeiro: movimentações e relatórios · Operador: lançamentos · Pessoal: só módulo pessoal
      </p>
    </div>

    <div class="flex justify-end gap-3 pt-4">
      <a href="/usuarios" class="px-5 py-2 text-slate-600 bg-white border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50">Cancelar</a>
      <button type="submit" class="px-5 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">Criar Usuário</button>
    </div>
  </form>
</div>
