<!-- views/usuarios/index.erb - Gestão de usuários -->

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Usuários</h1>
    <p class="text-slate-500 text-sm mt-1">Gestão de acesso ao sistema</p>
  </div>
  <a href="/usuarios/novo" class="px-4 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition flex items-center gap-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Novo Usuário
  </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50">
        <th class="px-5 py-3">Usuário</th>
        <th class="px-5 py-3">Email</th>
        <th class="px-5 py-3">Nível de Acesso</th>
        <th class="px-5 py-3">Último Login</th>
        <th class="px-5 py-3">Status</th>
        <th class="px-5 py-3 text-center">Ações</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @usuarios.each do |u| %>
        <tr class="hover:bg-slate-50">
          <td class="px-5 py-3">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center text-sm font-bold text-indigo-700">
                <%= u[:nome][0].upcase %>
              </div>
              <span class="font-medium text-slate-800"><%= u[:nome] %></span>
            </div>
          </td>
          <td class="px-5 py-3 text-slate-600"><%= u[:email] %></td>
          <td class="px-5 py-3">
            <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-indigo-100 text-indigo-700"><%= label_acesso(u[:nivel_acesso]) %></span>
          </td>
          <td class="px-5 py-3 text-slate-500 text-xs"><%= u[:ultimo_login] ? fmt_datetime(u[:ultimo_login]) : 'Nunca' %></td>
          <td class="px-5 py-3">
            <span class="px-2 py-1 text-xs font-medium rounded-full <%= u[:ativo] ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
              <%= u[:ativo] ? 'Ativo' : 'Inativo' %>
            </span>
          </td>
          <td class="px-5 py-3 text-center">
            <div class="flex items-center justify-center gap-2">
              <a href="/usuarios/<%= u[:id] %>/editar" class="text-slate-400 hover:text-indigo-600 transition" title="Editar">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              </a>
              <form action="/usuarios/<%= u[:id] %>" method="POST" onsubmit="return confirm('Desativar este usuário?')" class="inline">
                <input type="hidden" name="_method" value="DELETE">
                <button class="text-slate-400 hover:text-red-600 transition" title="Desativar">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                </button>
              </form>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
