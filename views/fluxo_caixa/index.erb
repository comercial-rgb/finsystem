<!-- views/fluxo_caixa/index.erb - Fluxo de Caixa Detalhado -->

<!-- Header -->
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Fluxo de Caixa</h1>
    <p class="text-slate-500 text-sm mt-1">
      Visão detalhada da saúde financeira &middot; <%= nome_mes(@mes) %>/<%= @ano %>
    </p>
  </div>

  <!-- Filtros -->
  <form method="GET" action="/fluxo-de-caixa" class="flex flex-wrap items-end gap-3">
    <select name="empresa_id" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500">
      <option value="">Todas as Empresas</option>
      <% @empresas.each do |emp| %>
        <option value="<%= emp[:id] %>" <%= @empresa_id.to_s == emp[:id].to_s ? 'selected' : '' %>>
          <%= emp[:nome_fantasia] %>
        </option>
      <% end %>
    </select>
    <select name="mes" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <% meses_select.each do |num, nome| %>
        <option value="<%= num %>" <%= @mes == num ? 'selected' : '' %>><%= nome %></option>
      <% end %>
    </select>
    <select name="ano" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <% anos_select.each do |a| %>
        <option value="<%= a %>" <%= @ano == a ? 'selected' : '' %>><%= a %></option>
      <% end %>
    </select>
    <button type="submit" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition">
      Filtrar
    </button>
  </form>
</div>

<!-- ========================================
     RESUMO FINANCEIRO DO MÊS
======================================== -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 mb-6">
  <div class="px-5 py-4 border-b border-slate-100">
    <h2 class="font-semibold text-slate-800">Resumo Financeiro — <%= nome_mes(@mes) %>/<%= @ano %></h2>
  </div>
  <div class="p-5">
    <!-- Entradas -->
    <div class="mb-6">
      <h3 class="text-sm font-semibold text-emerald-700 uppercase tracking-wide mb-3 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-emerald-500"></span> Entradas
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-cyan-50 rounded-lg p-4 border border-cyan-100">
          <p class="text-xs text-cyan-600 font-medium uppercase">Faturamento Bruto</p>
          <p class="text-xl font-bold text-cyan-700 mt-1"><%= fmt_moeda(@faturamento_bruto) %></p>
          <p class="text-xs text-slate-400 mt-1">Total recebido de clientes</p>
        </div>
        <div class="bg-emerald-50 rounded-lg p-4 border border-emerald-100">
          <p class="text-xs text-emerald-600 font-medium uppercase">Receita Real (Lucro)</p>
          <p class="text-xl font-bold text-emerald-700 mt-1"><%= fmt_moeda(@receita_real) %></p>
          <p class="text-xs text-slate-400 mt-1">Margem que fica na empresa</p>
        </div>
        <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
          <p class="text-xs text-slate-500 font-medium uppercase">Repasse a Fornecedores</p>
          <p class="text-xl font-bold text-slate-600 mt-1"><%= fmt_moeda(@repasse_fornecedores) %></p>
          <p class="text-xs text-slate-400 mt-1">Valor repassado (faturamento - lucro)</p>
        </div>
      </div>
    </div>

    <!-- Antecipações -->
    <div class="mb-6">
      <h3 class="text-sm font-semibold text-purple-700 uppercase tracking-wide mb-3 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-purple-500"></span> Antecipações
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-purple-50 rounded-lg p-4 border border-purple-100">
          <p class="text-xs text-purple-600 font-medium uppercase">Capital Antecipado</p>
          <p class="text-xl font-bold text-purple-700 mt-1"><%= fmt_moeda(@total_antecipado) %></p>
          <p class="text-xs text-slate-400 mt-1"><%= @qtd_antecipacoes %> operações no mês</p>
        </div>
        <div class="bg-purple-50 rounded-lg p-4 border border-purple-100">
          <p class="text-xs text-purple-600 font-medium uppercase">Lucro das Antecipações</p>
          <p class="text-xl font-bold text-emerald-600 mt-1"><%= fmt_moeda(@lucro_antecipacoes) %></p>
          <p class="text-xs text-slate-400 mt-1">Taxa/spread sobre antecipações</p>
        </div>
        <div class="bg-purple-50 rounded-lg p-4 border border-purple-100">
          <p class="text-xs text-purple-600 font-medium uppercase">ROI Antecipações</p>
          <% roi = @total_antecipado > 0 ? ((@lucro_antecipacoes / @total_antecipado) * 100).round(1) : 0 %>
          <p class="text-xl font-bold text-purple-700 mt-1"><%= roi %>%</p>
          <p class="text-xs text-slate-400 mt-1">Retorno sobre capital aplicado</p>
        </div>
      </div>
    </div>

    <!-- Saídas -->
    <div class="mb-6">
      <h3 class="text-sm font-semibold text-red-700 uppercase tracking-wide mb-3 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-red-500"></span> Saídas (Despesas Operacionais)
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-red-50 rounded-lg p-4 border border-red-100">
          <p class="text-xs text-red-600 font-medium uppercase">Total Despesas</p>
          <p class="text-xl font-bold text-red-700 mt-1"><%= fmt_moeda(@total_despesas) %></p>
        </div>
        <div class="bg-amber-50 rounded-lg p-4 border border-amber-100">
          <p class="text-xs text-amber-600 font-medium uppercase">Recorrentes</p>
          <p class="text-lg font-bold text-amber-700 mt-1"><%= fmt_moeda(@despesas_recorrentes) %></p>
          <p class="text-xs text-slate-400 mt-1">Mensais fixas</p>
        </div>
        <div class="bg-orange-50 rounded-lg p-4 border border-orange-100">
          <p class="text-xs text-orange-600 font-medium uppercase">Parceladas</p>
          <p class="text-lg font-bold text-orange-700 mt-1"><%= fmt_moeda(@despesas_parceladas) %></p>
          <p class="text-xs text-slate-400 mt-1">Em andamento</p>
        </div>
        <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
          <p class="text-xs text-slate-500 font-medium uppercase">Únicas / Avulsas</p>
          <p class="text-lg font-bold text-slate-600 mt-1"><%= fmt_moeda(@despesas_unicas + @despesas_sem_tipo) %></p>
        </div>
      </div>
    </div>

    <!-- Resultado -->
    <div class="border-t border-slate-200 pt-5">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="rounded-lg p-5 border-2 <%= @resultado_liquido >= 0 ? 'bg-emerald-50 border-emerald-200' : 'bg-red-50 border-red-200' %>">
          <p class="text-xs font-semibold uppercase tracking-wide <%= @resultado_liquido >= 0 ? 'text-emerald-600' : 'text-red-600' %>">Resultado Líquido do Mês</p>
          <p class="text-3xl font-bold mt-2 <%= @resultado_liquido >= 0 ? 'text-emerald-700' : 'text-red-700' %>"><%= fmt_moeda(@resultado_liquido) %></p>
          <p class="text-xs text-slate-400 mt-1">Receita Real + Lucro Antecipações − Despesas</p>
        </div>
        <div class="rounded-lg p-5 bg-blue-50 border-2 border-blue-200">
          <p class="text-xs font-semibold uppercase tracking-wide text-blue-600">Saldo Total em Contas</p>
          <p class="text-3xl font-bold mt-2 <%= @saldo_total >= 0 ? 'text-blue-700' : 'text-red-700' %>"><%= fmt_moeda(@saldo_total) %></p>
          <p class="text-xs text-slate-400 mt-1">Soma de todos os saldos bancários</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ========================================
     GRÁFICO DE EVOLUÇÃO + DESPESAS POR CATEGORIA
======================================== -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
  <!-- Gráfico de Evolução 6 meses -->
  <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-slate-200">
    <div class="px-5 py-4 border-b border-slate-100">
      <h2 class="font-semibold text-slate-800">Evolução — Receita Real vs Despesas (6 meses)</h2>
    </div>
    <div class="p-5">
      <canvas id="chartFluxoEvolucao" height="240"></canvas>
    </div>
  </div>

  <!-- Despesas por Categoria -->
  <div class="bg-white rounded-xl shadow-sm border border-slate-200">
    <div class="px-5 py-4 border-b border-slate-100">
      <h2 class="font-semibold text-slate-800">Para Onde Vai o Dinheiro</h2>
    </div>
    <div class="p-5">
      <% if @despesas_por_categoria.empty? %>
        <p class="text-sm text-slate-400 text-center py-6">Sem despesas neste período</p>
      <% else %>
        <div class="space-y-3">
          <% @despesas_por_categoria.first(8).each do |cat| %>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2 min-w-0">
                <span class="w-3 h-3 rounded-full flex-shrink-0" style="background-color: <%= cat[:cor] || '#6b7280' %>"></span>
                <span class="text-sm text-slate-700 truncate"><%= cat[:categoria] || 'Sem Categoria' %></span>
              </div>
              <div class="text-right flex-shrink-0 ml-3">
                <span class="text-sm font-bold text-slate-800"><%= fmt_moeda(cat[:total]) %></span>
                <span class="text-xs text-slate-400 ml-1">(<%= cat[:qtd] %>)</span>
              </div>
            </div>
            <% pct = @total_despesas > 0 ? ((cat[:total].to_f / @total_despesas) * 100).round(1) : 0 %>
            <div class="w-full bg-slate-100 rounded-full h-1.5 -mt-1">
              <div class="h-1.5 rounded-full" style="width: <%= pct %>%; background-color: <%= cat[:cor] || '#6b7280' %>"></div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- ========================================
     SALDOS BANCÁRIOS
======================================== -->
<% unless @saldos.empty? %>
<div class="bg-white rounded-xl shadow-sm border border-slate-200 mb-6">
  <div class="px-5 py-4 border-b border-slate-100">
    <h2 class="font-semibold text-slate-800">Saldos Bancários — Onde Está o Dinheiro</h2>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50">
          <th class="px-5 py-3">Banco / Conta</th>
          <th class="px-5 py-3">Empresa</th>
          <th class="px-5 py-3 text-right">Entradas</th>
          <th class="px-5 py-3 text-right">Saídas</th>
          <th class="px-5 py-3 text-right">Saldo Atual</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @saldos.each do |s| %>
          <% saldo = (s[:saldo_inicial] || 0) + (s[:total_entradas] || 0) - (s[:total_saidas] || 0) %>
          <tr class="hover:bg-slate-50">
            <td class="px-5 py-3">
              <div class="font-medium text-slate-800"><%= s[:banco] %></div>
              <div class="text-xs text-slate-400"><%= s[:apelido] %> · <%= s[:moeda] || 'BRL' %></div>
            </td>
            <td class="px-5 py-3 text-slate-600"><%= s[:empresa_nome] || '—' %></td>
            <td class="px-5 py-3 text-right text-emerald-600 font-medium"><%= fmt_moeda(s[:total_entradas] || 0, s[:moeda]) %></td>
            <td class="px-5 py-3 text-right text-red-600 font-medium"><%= fmt_moeda(s[:total_saidas] || 0, s[:moeda]) %></td>
            <td class="px-5 py-3 text-right font-bold <%= saldo >= 0 ? 'text-blue-700' : 'text-red-700' %>"><%= fmt_moeda(saldo, s[:moeda]) %></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr class="bg-slate-50 font-bold">
          <td class="px-5 py-3" colspan="4">Total Geral</td>
          <td class="px-5 py-3 text-right <%= @saldo_total >= 0 ? 'text-blue-700' : 'text-red-700' %>"><%= fmt_moeda(@saldo_total) %></td>
        </tr>
      </tfoot>
    </table>
  </div>
</div>
<% end %>

<!-- ========================================
     COMPROMISSOS FUTUROS
======================================== -->
<% if @pendentes_recorrentes && !@pendentes_recorrentes.empty? %>
<div class="bg-white rounded-xl shadow-sm border border-orange-200 mb-6">
  <div class="px-5 py-4 border-b border-orange-100 bg-orange-50 rounded-t-xl">
    <div class="flex items-center gap-2">
      <span class="text-lg">📅</span>
      <h2 class="font-semibold text-orange-800">Compromissos — Próximos 60 Dias</h2>
      <span class="px-2 py-0.5 bg-orange-200 text-orange-800 text-xs font-bold rounded-full"><%= @pendentes_recorrentes.size %></span>
    </div>
    <% total_pendente = @pendentes_recorrentes.sum { |p| p[:valor_bruto].to_f } %>
    <p class="text-sm text-orange-600 mt-1">Total pendente: <strong><%= fmt_moeda(total_pendente) %></strong></p>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50">
          <th class="px-5 py-3">Vencimento</th>
          <th class="px-5 py-3">Tipo</th>
          <th class="px-5 py-3">Descrição</th>
          <th class="px-5 py-3">Categoria</th>
          <th class="px-5 py-3">Empresa</th>
          <th class="px-5 py-3 text-right">Valor</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @pendentes_recorrentes.each do |p| %>
          <% vencido = p[:data_proximo_vencimento] && p[:data_proximo_vencimento] < Date.today %>
          <tr class="hover:bg-slate-50 <%= vencido ? 'bg-red-50' : '' %>">
            <td class="px-5 py-3 whitespace-nowrap font-medium <%= vencido ? 'text-red-600' : 'text-slate-600' %>">
              <%= fmt_data(p[:data_proximo_vencimento]) %>
              <% if vencido %><span class="text-xs text-red-500 font-bold ml-1">VENCIDO</span><% end %>
            </td>
            <td class="px-5 py-3">
              <% if p[:tipo_cobranca] == 'recorrente' %>
                <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-amber-100 text-amber-700">Recorrente</span>
              <% else %>
                <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-purple-100 text-purple-700"><%= p[:parcela_atual] %>/<%= p[:total_parcelas] %></span>
              <% end %>
            </td>
            <td class="px-5 py-3 font-medium text-slate-800"><%= truncar(p[:descricao], 45) %></td>
            <td class="px-5 py-3 text-slate-500"><%= p[:categoria_nome] || '—' %></td>
            <td class="px-5 py-3 text-slate-600"><%= p[:empresa_nome] || '—' %></td>
            <td class="px-5 py-3 text-right font-bold text-red-600"><%= fmt_moeda(p[:valor_bruto]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<% end %>

<!-- Chart.js -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const ctx = document.getElementById('chartFluxoEvolucao');
  if (ctx) {
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: [<%= @evolucao.map { |e| "'#{e[:mes]}'" }.join(',') %>],
        datasets: [
          {
            label: 'Receita Real',
            data: [<%= @evolucao.map { |e| e[:receita_real] }.join(',') %>],
            backgroundColor: 'rgba(16, 185, 129, 0.7)',
            borderColor: 'rgb(16, 185, 129)',
            borderWidth: 1, borderRadius: 4
          },
          {
            label: 'Lucro Antecipações',
            data: [<%= @evolucao.map { |e| e[:antecipacoes] }.join(',') %>],
            backgroundColor: 'rgba(147, 51, 234, 0.7)',
            borderColor: 'rgb(147, 51, 234)',
            borderWidth: 1, borderRadius: 4
          },
          {
            label: 'Despesas',
            data: [<%= @evolucao.map { |e| e[:despesas] }.join(',') %>],
            backgroundColor: 'rgba(239, 68, 68, 0.7)',
            borderColor: 'rgb(239, 68, 68)',
            borderWidth: 1, borderRadius: 4
          },
          {
            label: 'Resultado',
            data: [<%= @evolucao.map { |e| e[:resultado] }.join(',') %>],
            type: 'line',
            borderColor: 'rgb(99, 102, 241)',
            backgroundColor: 'rgba(99, 102, 241, 0.1)',
            borderWidth: 2, pointRadius: 4, tension: 0.3, fill: false
          }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: 15, font: { size: 11 } } } },
        scales: {
          y: { beginAtZero: true, ticks: { callback: v => 'R$ ' + v.toLocaleString('pt-BR') } },
          x: { grid: { display: false } }
        }
      }
    });
  }
});
</script>
