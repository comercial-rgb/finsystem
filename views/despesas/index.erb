<!-- views/despesas/index.erb - Despesas Reais da Empresa -->

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Despesas Reais</h1>
    <p class="text-slate-500 text-sm mt-1">Despesas operacionais da empresa (excluindo repasses e transferências) — <%= nome_mes(@mes) %>/<%= @ano %></p>
  </div>
  <div class="flex flex-wrap gap-2">
    <a href="/movimentacoes/nova" class="px-4 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Nova Despesa
    </a>
  </div>
</div>

<!-- Filtros -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 mb-6">
  <form method="GET" action="/despesas" class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-3">
    <div class="lg:col-span-2">
      <input type="text" name="busca" value="<%= @busca %>" placeholder="Buscar por descrição..." class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
    </div>
    <select name="empresa_id" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <option value="">Todas Empresas</option>
      <% @empresas.each do |emp| %>
        <option value="<%= emp[:id] %>" <%= @empresa_id.to_s == emp[:id].to_s ? 'selected' : '' %>><%= emp[:nome_fantasia] %></option>
      <% end %>
    </select>
    <select name="tipo_operacao" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <option value="">Todas Operações</option>
      <option value="aluguel" <%= @tipo_operacao == 'aluguel' ? 'selected' : '' %>>Aluguel</option>
      <option value="utilidade" <%= @tipo_operacao == 'utilidade' ? 'selected' : '' %>>Utilidades</option>
      <option value="servidor" <%= @tipo_operacao == 'servidor' ? 'selected' : '' %>>Servidores/Hosting</option>
      <option value="software" <%= @tipo_operacao == 'software' ? 'selected' : '' %>>Software/Licenças</option>
      <option value="ia" <%= @tipo_operacao == 'ia' ? 'selected' : '' %>>IA (APIs)</option>
      <option value="salario" <%= @tipo_operacao == 'salario' ? 'selected' : '' %>>Salários</option>
      <option value="prolabore" <%= @tipo_operacao == 'prolabore' ? 'selected' : '' %>>Pró-labore</option>
      <option value="imposto" <%= @tipo_operacao == 'imposto' ? 'selected' : '' %>>Impostos</option>
      <option value="contabilidade" <%= @tipo_operacao == 'contabilidade' ? 'selected' : '' %>>Contabilidade</option>
      <option value="marketing" <%= @tipo_operacao == 'marketing' ? 'selected' : '' %>>Marketing</option>
      <option value="retirada_socio" <%= @tipo_operacao == 'retirada_socio' ? 'selected' : '' %>>Retirada de Sócio</option>
      <option value="outros" <%= @tipo_operacao == 'outros' ? 'selected' : '' %>>Outros</option>
    </select>
    <select name="mes" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <% meses_select.each do |num, nome| %>
        <option value="<%= num %>" <%= @mes == num ? 'selected' : '' %>><%= nome %></option>
      <% end %>
    </select>
    <select name="ano" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <% anos_select.each do |a| %>
        <option value="<%= a %>" <%= @ano == a ? 'selected' : '' %>><%= a %></option>
      <% end %>
    </select>
    <button type="submit" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition">Filtrar</button>
  </form>
</div>

<!-- Resumo -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
  <div class="bg-red-50 rounded-xl p-4 border border-red-200">
    <p class="text-xs text-red-600 font-semibold uppercase">Total Despesas Reais</p>
    <p class="text-2xl font-bold text-red-700 mt-1"><%= fmt_moeda(@total_despesas) %></p>
    <p class="text-xs text-red-500 mt-1"><%= @total_registros %> lançamentos</p>
  </div>
  <div class="bg-white rounded-xl p-4 border border-slate-200">
    <p class="text-xs text-slate-600 font-semibold uppercase mb-2">Por Categoria</p>
    <div class="space-y-1.5 max-h-32 overflow-y-auto">
      <% @por_categoria.each do |cat| %>
        <div class="flex justify-between items-center text-xs">
          <span class="text-slate-600"><%= cat[:categoria] %> (<%= cat[:qtd] %>)</span>
          <span class="font-semibold text-red-600"><%= fmt_moeda(cat[:total]) %></span>
        </div>
      <% end %>
      <% if @por_categoria.empty? %>
        <p class="text-xs text-slate-400">Nenhuma despesa no período</p>
      <% end %>
    </div>
  </div>
</div>

<!-- Tabela -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50">
          <th class="px-4 py-3">Data</th>
          <th class="px-4 py-3">Descrição</th>
          <th class="px-4 py-3">Categoria</th>
          <th class="px-4 py-3">Operação</th>
          <th class="px-4 py-3">Empresa</th>
          <th class="px-4 py-3">Banco</th>
          <th class="px-4 py-3 text-right">Valor</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3 text-center">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @movimentacoes.each do |m| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-4 py-3 text-slate-600 whitespace-nowrap"><%= fmt_data(m[:data_movimentacao]) %></td>
            <td class="px-4 py-3">
              <div class="font-medium text-slate-800 max-w-[250px] truncate"><%= m[:descricao] %></div>
              <% if m[:fornecedor_nome] %>
                <div class="text-xs text-slate-400">Fornecedor: <%= m[:fornecedor_nome] %></div>
              <% end %>
              <% if m[:numero_documento] %>
                <div class="text-xs text-slate-400">Doc: <%= m[:numero_documento] %></div>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <% if m[:categoria_nome] %>
                <span class="inline-flex items-center gap-1">
                  <span class="w-2 h-2 rounded-full" style="background-color: <%= m[:categoria_cor] %>"></span>
                  <span class="text-slate-600 text-xs"><%= m[:categoria_nome] %></span>
                </span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-xs text-slate-500"><%= m[:tipo_operacao]&.gsub('_', ' ')&.capitalize || '-' %></td>
            <td class="px-4 py-3 text-slate-600 text-xs"><%= m[:empresa_nome] %></td>
            <td class="px-4 py-3 text-slate-600 text-xs"><%= m[:banco_nome] %></td>
            <td class="px-4 py-3 text-right font-bold text-red-600 whitespace-nowrap">
              - <%= fmt_moeda(m[:valor_bruto]) %>
            </td>
            <td class="px-4 py-3"><%= badge_status(m[:status]) %></td>
            <td class="px-4 py-3 text-center">
              <div class="flex items-center justify-center gap-1">
                <button onclick="showDetalheModal(<%= m[:id] %>)" class="p-1.5 text-slate-400 hover:text-cyan-600 transition" title="Detalhes">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                </button>
                <a href="/movimentacoes/<%= m[:id] %>/editar" class="p-1.5 text-slate-400 hover:text-indigo-600 transition" title="Editar">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                </a>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% if @movimentacoes.empty? %>
    <div class="text-center py-12">
      <p class="text-slate-400 text-sm">Nenhuma despesa real encontrada com estes filtros</p>
    </div>
  <% end %>

  <!-- Paginação -->
  <div class="px-5 py-3 border-t border-slate-100 flex flex-wrap justify-between items-center bg-slate-50 gap-3">
    <span class="text-xs text-slate-500"><%= @total_registros %> despesas (página <%= @page %> de <%= @total_pages %>)</span>
    <div class="flex items-center gap-2">
      <% if @total_pages > 1 %>
        <% if @page > 1 %>
          <a href="/despesas?page=<%= @page - 1 %>&mes=<%= @mes %>&ano=<%= @ano %>&empresa_id=<%= @empresa_id %>&tipo_operacao=<%= @tipo_operacao %>&busca=<%= @busca %>" class="px-3 py-1 text-xs bg-white border border-slate-300 rounded hover:bg-slate-50">&laquo; Anterior</a>
        <% end %>
        <% (1..@total_pages).each do |p| %>
          <% if p == @page %>
            <span class="px-3 py-1 text-xs bg-indigo-600 text-white rounded"><%= p %></span>
          <% elsif (p - @page).abs <= 2 || p == 1 || p == @total_pages %>
            <a href="/despesas?page=<%= p %>&mes=<%= @mes %>&ano=<%= @ano %>&empresa_id=<%= @empresa_id %>&tipo_operacao=<%= @tipo_operacao %>&busca=<%= @busca %>" class="px-3 py-1 text-xs bg-white border border-slate-300 rounded hover:bg-slate-50"><%= p %></a>
          <% elsif (p - @page).abs == 3 %>
            <span class="text-xs text-slate-400">...</span>
          <% end %>
        <% end %>
        <% if @page < @total_pages %>
          <a href="/despesas?page=<%= @page + 1 %>&mes=<%= @mes %>&ano=<%= @ano %>&empresa_id=<%= @empresa_id %>&tipo_operacao=<%= @tipo_operacao %>&busca=<%= @busca %>" class="px-3 py-1 text-xs bg-white border border-slate-300 rounded hover:bg-slate-50">Próxima &raquo;</a>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<!-- Modal Detalhes (reutilizado do index) -->
<div id="detalhe-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
  <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full mx-4 max-h-[90vh] overflow-y-auto">
    <div class="p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold text-slate-800">Detalhes da Movimentação</h3>
        <button onclick="closeDetalheModal()" class="p-1 text-slate-400 hover:text-slate-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="detalhe-content" class="space-y-3">
        <p class="text-sm text-slate-400">Carregando...</p>
      </div>
    </div>
  </div>
</div>

<script>
// Dados das movimentações para o modal de detalhes
var movimentacoesData = {};
<% @movimentacoes.each do |m| %>
movimentacoesData[<%= m[:id] %>] = {
  id: <%= m[:id] %>,
  tipo: '<%= m[:tipo] %>',
  descricao: '<%= m[:descricao]&.gsub("'", "\\\\'") %>',
  data: '<%= fmt_data(m[:data_movimentacao]) %>',
  valor: '<%= fmt_moeda(m[:valor_bruto]) %>',
  status: '<%= m[:status] %>',
  categoria: '<%= m[:categoria_nome] || "-" %>',
  empresa: '<%= m[:empresa_nome] || "-" %>',
  banco: '<%= m[:banco_nome] || "-" %>',
  fornecedor: '<%= m[:fornecedor_nome] || "-" %>',
  tipo_operacao: '<%= m[:tipo_operacao]&.gsub("_", " ")&.capitalize || "-" %>',
  forma_pagamento: '<%= m[:forma_pagamento]&.gsub("_", " ")&.capitalize || "-" %>',
  numero_documento: '<%= m[:numero_documento] || "-" %>',
  observacoes: '<%= m[:observacoes]&.gsub("'", "\\\\'")&.gsub("\n", " ") || "-" %>',
  conciliado: <%= m[:conciliado] ? 'true' : 'false' %>
};
<% end %>

function showDetalheModal(id) {
  var m = movimentacoesData[id];
  if (!m) return;
  var html = '<div class="grid grid-cols-2 gap-3 text-sm">' +
    '<div><span class="text-slate-400 text-xs block">ID</span><span class="font-medium">#' + m.id + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Data</span><span class="font-medium">' + m.data + '</span></div>' +
    '<div class="col-span-2"><span class="text-slate-400 text-xs block">Descrição</span><span class="font-medium">' + m.descricao + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Valor</span><span class="font-bold text-red-600">- ' + m.valor + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Status</span><span class="font-medium capitalize">' + m.status + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Categoria</span><span class="font-medium">' + m.categoria + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Tipo Operação</span><span class="font-medium">' + m.tipo_operacao + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Empresa</span><span class="font-medium">' + m.empresa + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Banco</span><span class="font-medium">' + m.banco + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Fornecedor</span><span class="font-medium">' + m.fornecedor + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Forma Pagamento</span><span class="font-medium">' + m.forma_pagamento + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Nº Documento</span><span class="font-medium">' + m.numero_documento + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Conciliado</span><span class="font-medium">' + (m.conciliado ? '✅ Sim' : '❌ Não') + '</span></div>' +
    '<div class="col-span-2"><span class="text-slate-400 text-xs block">Observações</span><span class="font-medium">' + m.observacoes + '</span></div>' +
    '</div>' +
    '<div class="mt-4 flex justify-end"><a href="/movimentacoes/' + m.id + '/editar" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm hover:bg-indigo-700">Editar</a></div>';
  document.getElementById('detalhe-content').innerHTML = html;
  document.getElementById('detalhe-modal').classList.remove('hidden');
  document.getElementById('detalhe-modal').classList.add('flex');
}

function closeDetalheModal() {
  document.getElementById('detalhe-modal').classList.add('hidden');
  document.getElementById('detalhe-modal').classList.remove('flex');
}

document.getElementById('detalhe-modal').addEventListener('click', function(e) {
  if (e.target === this) closeDetalheModal();
});
</script>
