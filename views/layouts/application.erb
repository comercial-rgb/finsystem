<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Administração - Gestão Financeira</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png">
  <link rel="apple-touch-icon" href="/favicon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <script src="/js/app.js" defer></script>
</head>
<body class="bg-slate-100 min-h-screen">
  <div class="flex min-h-screen">
    <!-- ========================================
         SIDEBAR
    ======================================== -->
    <aside class="sidebar sidebar-expanded bg-slate-900 text-white flex flex-col fixed h-full z-30" id="sidebar">
      <!-- Logo InstaSolutions -->
      <div class="p-5 border-b border-slate-700/50">
        <a href="/" class="flex items-center gap-3">
          <img src="/images/logo-simbolo.png" alt="InstaSolutions" class="w-10 h-10 flex-shrink-0 object-contain" onerror="this.style.display='none'">
          <div class="sidebar-label">
            <h1 class="font-bold text-lg leading-tight">FinSystem</h1>
            <p class="text-xs text-slate-400">InstaSolutions</p>
          </div>
        </a>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 p-3 space-y-1 overflow-y-auto">
        <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 transition-colors <%= request.path_info == '/' ? 'bg-slate-800 text-indigo-400' : 'text-slate-300' %>">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
          </svg>
          <span class="sidebar-label text-sm font-medium">Dashboard</span>
        </a>

        <a href="/movimentacoes" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 transition-colors <%= request.path_info.start_with?('/movimentacoes') ? 'bg-slate-800 text-indigo-400' : 'text-slate-300' %>">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>
          </svg>
          <span class="sidebar-label text-sm font-medium">Movimentações</span>
        </a>

        <a href="/empresas" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 transition-colors <%= request.path_info.start_with?('/empresas') ? 'bg-slate-800 text-indigo-400' : 'text-slate-300' %>">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          <span class="sidebar-label text-sm font-medium">Empresas</span>
        </a>

        <a href="/clientes" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 transition-colors <%= request.path_info.start_with?('/clientes') ? 'bg-slate-800 text-indigo-400' : 'text-slate-300' %>">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span class="sidebar-label text-sm font-medium">Clientes</span>
        </a>

        <a href="/fornecedores" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 transition-colors <%= request.path_info.start_with?('/fornecedores') ? 'bg-slate-800 text-indigo-400' : 'text-slate-300' %>">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
          </svg>
          <span class="sidebar-label text-sm font-medium">Fornecedores</span>
        </a>

        <a href="/relatorios" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 transition-colors <%= request.path_info.start_with?('/relatorios') ? 'bg-slate-800 text-indigo-400' : 'text-slate-300' %>">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <span class="sidebar-label text-sm font-medium">Relatórios</span>
        </a>

        <a href="/cartoes" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 transition-colors <%= request.path_info.start_with?('/cartoes') ? 'bg-slate-800 text-indigo-400' : 'text-slate-300' %>">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
          <span class="sidebar-label text-sm font-medium">Cartões de Crédito</span>
        </a>

        <div class="pt-3 mt-3 border-t border-slate-700/50">
          <p class="px-3 text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2 sidebar-label">Pessoal</p>
          <a href="/pessoal" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 transition-colors <%= request.path_info == '/pessoal' ? 'bg-slate-800 text-emerald-400' : 'text-slate-300' %>">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <span class="sidebar-label text-sm font-medium">Minhas Finanças</span>
          </a>
          <a href="/pessoal/cartoes" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 transition-colors <%= request.path_info.start_with?('/pessoal/cartoes') ? 'bg-slate-800 text-emerald-400' : 'text-slate-300' %>">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
            <span class="sidebar-label text-sm font-medium">Meus Cartões</span>
          </a>
        </div>

        <% if usuario_logado && FinSystem::Models::Usuario.tem_permissao?(usuario_logado, 'admin') %>
          <div class="pt-3 mt-3 border-t border-slate-700/50">
            <p class="px-3 text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2 sidebar-label">Admin</p>
            <a href="/usuarios" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 transition-colors <%= request.path_info.start_with?('/usuarios') ? 'bg-slate-800 text-indigo-400' : 'text-slate-300' %>">
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
              <span class="sidebar-label text-sm font-medium">Usuários</span>
            </a>
            <a href="/auditoria" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 transition-colors text-slate-300">
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
              <span class="sidebar-label text-sm font-medium">Auditoria</span>
            </a>
          </div>
        <% end %>
      </nav>

      <!-- User Info -->
      <div class="p-4 border-t border-slate-700/50">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-indigo-600 flex items-center justify-center text-sm font-bold flex-shrink-0">
            <%= usuario_logado[:nome][0].upcase %>
          </div>
          <div class="sidebar-label flex-1 min-w-0">
            <p class="text-sm font-medium truncate"><%= usuario_logado[:nome] %></p>
            <p class="text-xs text-slate-400"><%= label_acesso(usuario_logado[:nivel_acesso]) %></p>
          </div>
          <a href="/auth/logout" class="text-slate-400 hover:text-red-400 transition-colors" title="Sair">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
          </a>
        </div>
      </div>
    </aside>

    <!-- ========================================
         MAIN CONTENT
    ======================================== -->
    <main class="flex-1 ml-[260px] min-h-screen">
      <!-- Flash Messages -->
      <% if flash_message %>
        <div class="bg-emerald-50 border-l-4 border-emerald-500 text-emerald-700 p-4 fade-in" id="flash-success">
          <div class="flex items-center justify-between">
            <p class="text-sm font-medium"><%= flash_message %></p>
            <button onclick="this.parentElement.parentElement.remove()" class="text-emerald-500 hover:text-emerald-700">&times;</button>
          </div>
        </div>
      <% end %>
      <% if flash_error %>
        <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 fade-in" id="flash-error">
          <div class="flex items-center justify-between">
            <p class="text-sm font-medium"><%= flash_error %></p>
            <button onclick="this.parentElement.parentElement.remove()" class="text-red-500 hover:text-red-700">&times;</button>
          </div>
        </div>
      <% end %>

      <div class="p-6 fade-in">
        <%= yield %>
      </div>
    </main>
  </div>
</body>
</html>
