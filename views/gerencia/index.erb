              <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Status</th>
              <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Ações</th>
            </tr></thead>
            <tbody class="divide-y divide-slate-100">
              <% @licitacoes.each do |l| %>
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 font-medium text-slate-800"><%= l[:nome_orgao] %></td>
                  <td class="px-4 py-3 text-slate-600"><%= [l[:cidade], l[:uf]].compact.reject(&:empty?).join('/') %></td>
                  <td class="px-4 py-3 text-slate-600"><%= l[:numero_edital] || '-' %></td>
                  <td class="px-4 py-3 text-slate-600 text-xs"><%= truncar(l[:objeto], 30) %></td>
                  <td class="px-4 py-3 font-semibold text-slate-700"><%= l[:valor_estimado].to_f > 0 ? fmt_moeda(l[:valor_estimado]) : '-' %></td>
                  <td class="px-4 py-3 text-slate-500"><%= l[:data_abertura] ? fmt_data(l[:data_abertura]) : '-' %></td>
                  <td class="px-4 py-3 text-slate-500 text-xs"><%= l[:portal] || '-' %></td>
                  <td class="px-4 py-3">
                    <% lic_cores = {'inserida'=>'purple','cadastrada'=>'blue','andamento'=>'amber','ganha'=>'emerald','finalizada'=>'slate'} %>
                    <% lic_labels = {'inserida'=>'Inserida','cadastrada'=>'Cadastrada','andamento'=>'Andamento','ganha'=>'Ganha','finalizada'=>'Finalizada'} %>
                    <span class="px-2 py-1 text-xs font-medium rounded-full bg-<%= lic_cores[l[:status]] || 'slate' %>-100 text-<%= lic_cores[l[:status]] || 'slate' %>-800"><%= lic_labels[l[:status]] || l[:status] %></span>
                  </td>
                  <td class="px-4 py-3 flex gap-1 flex-wrap">
                    <% ['inserida','cadastrada','andamento','ganha','finalizada'].each do |st| %>
                      <% next if st == l[:status] %>
                      <form method="POST" action="/gerencia/licitacoes/<%= l[:id] %>" class="inline">
                        <input type="hidden" name="_method" value="PUT">
                        <input type="hidden" name="status" value="<%= st %>">
                        <button type="submit" class="text-<%= lic_cores[st] %>-600 hover:text-<%= lic_cores[st] %>-800 text-xs font-medium" title="<%= lic_labels[st] %>"><%= lic_labels[st][0..2] %></button>
                      </form>
                    <% end %>
                    <form method="POST" action="/gerencia/licitacoes/<%= l[:id] %>" onsubmit="return confirm('Excluir?')" class="inline">
                      <input type="hidden" name="_method" value="DELETE">
                      <button type="submit" class="text-red-500 hover:text-red-700 text-xs font-medium">Excluir</button>
                    </form>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-slate-400 text-sm text-center py-6">Nenhuma licitação registrada.</p>
      <% end %>

    <!-- ==============================
         ABA: OPERAÇÕES E SUPORTE
    ============================== -->
    <% elsif aba == 'operacoes' %>

      <!-- TREINAMENTOS -->
      <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-slate-800">Treinamentos Realizados</h2>
          <button onclick="document.getElementById('form-treinamento').classList.toggle('hidden')" class="px-4 py-2 bg-teal-600 text-white rounded-lg text-sm font-medium hover:bg-teal-700 transition">
            + Novo Treinamento
          </button>
        </div>

        <div id="form-treinamento" class="hidden bg-slate-50 rounded-lg p-5 mb-4 border border-slate-200">
          <form method="POST" action="/gerencia/treinamentos">
            <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Cliente/Fornecedor *</label>
                <input type="text" name="nome_cliente_fornecedor" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Solução Treinada</label>
                <select name="solucao_treinada" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                  <option value="">Selecione...</option>
                  <option value="manutencao">Manutenção</option>
                  <option value="combustivel">Combustível</option>
                  <option value="rastreamento">Rastreamento</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Quem Treinou</label>
                <input type="text" name="quem_treinou" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Data</label>
                <input type="date" name="data_treinamento" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
              <div class="flex items-end">
                <button type="submit" class="w-full px-4 py-2 bg-teal-600 text-white rounded-lg text-sm font-medium hover:bg-teal-700 transition">Salvar</button>
              </div>
            </div>
            <div class="mt-3">
              <label class="block text-xs font-semibold text-slate-600 mb-1">Observações</label>
              <input type="text" name="observacoes" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
            </div>
          </form>
        </div>

        <% if @treinamentos.any? %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead><tr class="bg-slate-50 text-left">
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Cliente/Fornecedor</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Solução</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Quem Treinou</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Data</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Observações</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Ações</th>
              </tr></thead>
              <tbody class="divide-y divide-slate-100">
                <% @treinamentos.each do |t| %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-4 py-3 font-medium text-slate-800"><%= t[:nome_cliente_fornecedor] %></td>
                    <td class="px-4 py-3">
                      <% sol_labels = {'manutencao'=>'Manutenção','combustivel'=>'Combustível','rastreamento'=>'Rastreamento'} %>
                      <% sol_cores = {'manutencao'=>'cyan','combustivel'=>'orange','rastreamento'=>'violet'} %>
                      <% if t[:solucao_treinada] && !t[:solucao_treinada].empty? %>
                        <span class="px-2 py-1 text-xs font-medium rounded-full bg-<%= sol_cores[t[:solucao_treinada]] || 'slate' %>-100 text-<%= sol_cores[t[:solucao_treinada]] || 'slate' %>-800"><%= sol_labels[t[:solucao_treinada]] || t[:solucao_treinada] %></span>
                      <% else %>-<% end %>
                    </td>
                    <td class="px-4 py-3 text-slate-600"><%= t[:quem_treinou] || '-' %></td>
                    <td class="px-4 py-3 text-slate-500"><%= t[:data_treinamento] ? fmt_data(t[:data_treinamento]) : '-' %></td>
                    <td class="px-4 py-3 text-slate-500 text-xs"><%= truncar(t[:observacoes], 30) %></td>
                    <td class="px-4 py-3">
                      <form method="POST" action="/gerencia/treinamentos/<%= t[:id] %>" onsubmit="return confirm('Excluir?')">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="text-red-500 hover:text-red-700 text-xs font-medium">Excluir</button>
                      </form>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-slate-400 text-sm text-center py-6">Nenhum treinamento registrado.</p>
        <% end %>
      </div>

      <hr class="my-8 border-slate-200">

      <!-- CHAMADOS -->
      <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-slate-800">Chamados Abertos</h2>
          <button onclick="document.getElementById('form-chamado').classList.toggle('hidden')" class="px-4 py-2 bg-rose-600 text-white rounded-lg text-sm font-medium hover:bg-rose-700 transition">
            + Novo Chamado
          </button>
        </div>

        <div id="form-chamado" class="hidden bg-slate-50 rounded-lg p-5 mb-4 border border-slate-200">
          <form method="POST" action="/gerencia/chamados">
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Solução *</label>
                <select name="solucao" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                  <option value="">Selecione...</option>
                  <option value="manutencao">Manutenção</option>
                  <option value="combustivel">Combustível</option>
                  <option value="rastreamento">Rastreamento</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Descrição *</label>
                <input type="text" name="descricao" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Aberto por</label>
                <input type="text" name="aberto_por" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Origem</label>
                <select name="origem" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                  <option value="equipe">Nossa Equipe</option>
                  <option value="fornecedor">Fornecedor</option>
                  <option value="cliente">Cliente</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Prioridade</label>
                <select name="prioridade" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                  <option value="baixa">Baixa</option>
                  <option value="media" selected>Média</option>
                  <option value="alta">Alta</option>
                  <option value="critica">Crítica</option>
                </select>
              </div>
              <div class="flex items-end">
                <button type="submit" class="w-full px-4 py-2 bg-rose-600 text-white rounded-lg text-sm font-medium hover:bg-rose-700 transition">Salvar</button>
              </div>
            </div>
          </form>
        </div>

        <!-- Resumo Chamados por Solução -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
          <% ['manutencao', 'combustivel', 'rastreamento'].each do |sol| %>
            <% qtd = @chamados.count { |c| c[:solucao] == sol && c[:status] == 'aberto' } %>
            <% cor = sol == 'manutencao' ? 'cyan' : (sol == 'combustivel' ? 'orange' : 'violet') %>
            <% label = sol == 'manutencao' ? 'Manutenção' : (sol == 'combustivel' ? 'Combustível' : 'Rastreamento') %>
            <div class="bg-<%= cor %>-50 rounded-lg p-3 border border-<%= cor %>-200 flex items-center justify-between">
              <div>
                <p class="text-xs font-semibold text-<%= cor %>-600 uppercase"><%= label %></p>
                <p class="text-xs text-<%= cor %>-500 mt-0.5">Chamados abertos</p>
              </div>
              <p class="text-2xl font-bold text-<%= cor %>-700"><%= qtd %></p>
            </div>
          <% end %>
        </div>

        <% if @chamados.any? %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead><tr class="bg-slate-50 text-left">
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Solução</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Descrição</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Aberto por</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Origem</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Prioridade</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Status</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Data</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Ações</th>
              </tr></thead>
              <tbody class="divide-y divide-slate-100">
                <% @chamados.each do |ch| %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-4 py-3">
                      <% sol_labels = {'manutencao'=>'Manutenção','combustivel'=>'Combustível','rastreamento'=>'Rastreamento'} %>
                      <% sol_cores = {'manutencao'=>'cyan','combustivel'=>'orange','rastreamento'=>'violet'} %>
                      <span class="px-2 py-1 text-xs font-medium rounded-full bg-<%= sol_cores[ch[:solucao]] || 'slate' %>-100 text-<%= sol_cores[ch[:solucao]] || 'slate' %>-800"><%= sol_labels[ch[:solucao]] || ch[:solucao] %></span>
                    </td>
                    <td class="px-4 py-3 text-slate-700"><%= truncar(ch[:descricao], 35) %></td>
                    <td class="px-4 py-3 text-slate-600"><%= ch[:aberto_por] || '-' %></td>
                    <td class="px-4 py-3">
                      <% orig_labels = {'equipe'=>'Equipe','fornecedor'=>'Fornecedor','cliente'=>'Cliente'} %>
                      <span class="text-xs font-medium text-slate-600"><%= orig_labels[ch[:origem]] || ch[:origem] %></span>
                    </td>
                    <td class="px-4 py-3">
                      <% pri_cores = {'baixa'=>'slate','media'=>'blue','alta'=>'amber','critica'=>'red'} %>
                      <span class="px-2 py-1 text-xs font-medium rounded-full bg-<%= pri_cores[ch[:prioridade]] || 'slate' %>-100 text-<%= pri_cores[ch[:prioridade]] || 'slate' %>-800"><%= ch[:prioridade]&.capitalize %></span>
                    </td>
                    <td class="px-4 py-3">
                      <% ch_st_cores = {'aberto'=>'red','andamento'=>'amber','resolvido'=>'emerald','fechado'=>'slate'} %>
                      <% ch_st_labels = {'aberto'=>'Aberto','andamento'=>'Andamento','resolvido'=>'Resolvido','fechado'=>'Fechado'} %>
                      <span class="px-2 py-1 text-xs font-medium rounded-full bg-<%= ch_st_cores[ch[:status]] || 'slate' %>-100 text-<%= ch_st_cores[ch[:status]] || 'slate' %>-800"><%= ch_st_labels[ch[:status]] || ch[:status] %></span>
                    </td>
                    <td class="px-4 py-3 text-slate-500 text-xs"><%= ch[:created_at] ? fmt_datetime(ch[:created_at]) : '-' %></td>
                    <td class="px-4 py-3 flex gap-1 flex-wrap">
                      <% ['aberto','andamento','resolvido','fechado'].each do |st| %>
                        <% next if st == ch[:status] %>
                        <form method="POST" action="/gerencia/chamados/<%= ch[:id] %>" class="inline">
                          <input type="hidden" name="_method" value="PUT">
                          <input type="hidden" name="status" value="<%= st %>">
                          <button type="submit" class="text-<%= ch_st_cores[st] %>-600 hover:text-<%= ch_st_cores[st] %>-800 text-xs font-medium"><%= ch_st_labels[st][0..2] %></button>
                        </form>
                      <% end %>
                      <form method="POST" action="/gerencia/chamados/<%= ch[:id] %>" onsubmit="return confirm('Excluir?')" class="inline">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="text-red-500 hover:text-red-700 text-xs font-medium">Excluir</button>
                      </form>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-slate-400 text-sm text-center py-6">Nenhum chamado registrado.</p>
        <% end %>
      </div>

      <hr class="my-8 border-slate-200">

      <!-- MELHORIAS IMPLANTADAS -->
      <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-slate-800">Melhorias Implantadas</h2>
          <button onclick="document.getElementById('form-melhoria').classList.toggle('hidden')" class="px-4 py-2 bg-sky-600 text-white rounded-lg text-sm font-medium hover:bg-sky-700 transition">
            + Nova Melhoria
          </button>
        </div>

        <div id="form-melhoria" class="hidden bg-slate-50 rounded-lg p-5 mb-4 border border-slate-200">
          <form method="POST" action="/gerencia/melhorias">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Título *</label>
                <input type="text" name="titulo" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Solução</label>
                <select name="solucao" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                  <option value="geral">Geral</option>
                  <option value="manutencao">Manutenção</option>
                  <option value="combustivel">Combustível</option>
                  <option value="rastreamento">Rastreamento</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Status</label>
                <select name="status" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                  <option value="planejada">Planejada</option>
                  <option value="desenvolvimento">Em Desenvolvimento</option>
                  <option value="implantada">Implantada</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Data Implantação</label>
                <input type="date" name="data_implantacao" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
            </div>
            <div class="mt-3">
              <label class="block text-xs font-semibold text-slate-600 mb-1">Descrição</label>
              <textarea name="descricao" rows="2" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm"></textarea>
            </div>
            <div class="mt-3 flex justify-end">
              <button type="submit" class="px-6 py-2 bg-sky-600 text-white rounded-lg text-sm font-medium hover:bg-sky-700 transition">Salvar</button>
            </div>
          </form>
        </div>

        <% if @melhorias.any? %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead><tr class="bg-slate-50 text-left">
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Título</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Descrição</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Solução</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Status</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Data Impl.</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Ações</th>
              </tr></thead>
              <tbody class="divide-y divide-slate-100">
                <% @melhorias.each do |m| %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-4 py-3 font-medium text-slate-800"><%= m[:titulo] %></td>
                    <td class="px-4 py-3 text-slate-600 text-xs"><%= truncar(m[:descricao], 40) %></td>
                    <td class="px-4 py-3">
                      <% sol_labels = {'manutencao'=>'Manutenção','combustivel'=>'Combustível','rastreamento'=>'Rastreamento','geral'=>'Geral'} %>
                      <span class="text-xs font-medium text-slate-600"><%= sol_labels[m[:solucao]] || m[:solucao] %></span>
                    </td>
                    <td class="px-4 py-3">
                      <% mel_cores = {'planejada'=>'slate','desenvolvimento'=>'amber','implantada'=>'emerald'} %>
                      <% mel_labels = {'planejada'=>'Planejada','desenvolvimento'=>'Em Desenvolvimento','implantada'=>'Implantada'} %>
                      <span class="px-2 py-1 text-xs font-medium rounded-full bg-<%= mel_cores[m[:status]] || 'slate' %>-100 text-<%= mel_cores[m[:status]] || 'slate' %>-800"><%= mel_labels[m[:status]] || m[:status] %></span>
                    </td>
                    <td class="px-4 py-3 text-slate-500"><%= m[:data_implantacao] ? fmt_data(m[:data_implantacao]) : '-' %></td>
                    <td class="px-4 py-3 flex gap-1 flex-wrap">
                      <% ['planejada','desenvolvimento','implantada'].each do |st| %>
                        <% next if st == m[:status] %>
                        <form method="POST" action="/gerencia/melhorias/<%= m[:id] %>" class="inline">
                          <input type="hidden" name="_method" value="PUT">
                          <input type="hidden" name="status" value="<%= st %>">
                          <button type="submit" class="text-<%= mel_cores[st] %>-600 hover:text-<%= mel_cores[st] %>-800 text-xs font-medium"><%= mel_labels[st][0..2] %></button>
                        </form>
                      <% end %>
                      <form method="POST" action="/gerencia/melhorias/<%= m[:id] %>" onsubmit="return confirm('Excluir?')" class="inline">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="text-red-500 hover:text-red-700 text-xs font-medium">Excluir</button>
                      </form>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-slate-400 text-sm text-center py-6">Nenhuma melhoria registrada.</p>
        <% end %>
      </div>

    <% end %>
  </div>
</div>
