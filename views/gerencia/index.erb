        <a href="/gerencia?aba=parceiros&parc_status=aguardando" class="px-3 py-1.5 rounded-full text-xs font-medium <%= params[:parc_status] == 'aguardando' ? 'bg-amber-600 text-white' : 'bg-amber-50 text-amber-700 hover:bg-amber-100' %>">Aguardando</a>
        <a href="/gerencia?aba=parceiros&parc_status=fracassado" class="px-3 py-1.5 rounded-full text-xs font-medium <%= params[:parc_status] == 'fracassado' ? 'bg-red-600 text-white' : 'bg-red-50 text-red-700 hover:bg-red-100' %>">Fracassados</a>
