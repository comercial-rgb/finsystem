<!-- views/gerencia/index.erb - Painel de Gerência Completo -->

<% aba = @aba || 'financeiro' %>

<!-- Header -->
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Painel de Gerência</h1>
    <p class="text-slate-500 text-sm mt-1">Controle completo de operações, financeiro, comercial e suporte</p>
  </div>
</div>

<!-- KPI Cards Resumo Geral -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
  <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-200">
    <div class="flex items-center gap-2 mb-2">
      <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center">
        <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/></svg>
      </div>
      <span class="text-xs font-semibold text-slate-500 uppercase">Recebimentos</span>
    </div>
    <p class="text-lg font-bold text-emerald-600"><%= fmt_moeda(@resumo[:financeiro][:total_recebimentos]) %></p>
  </div>

  <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-200">
    <div class="flex items-center gap-2 mb-2">
      <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center">
        <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </div>
      <span class="text-xs font-semibold text-slate-500 uppercase">NF Abertas</span>
    </div>
    <p class="text-lg font-bold text-amber-600"><%= @resumo[:financeiro][:nf_clientes_abertas] + @resumo[:financeiro][:nf_fornecedores_abertas] %></p>
  </div>

  <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-200">
    <div class="flex items-center gap-2 mb-2">
      <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center">
        <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </div>
      <span class="text-xs font-semibold text-slate-500 uppercase">Parceiros</span>
    </div>
    <p class="text-lg font-bold text-blue-600"><%= @resumo[:parceiros][:credenciados] %>/<%= @resumo[:parceiros][:total] %></p>
  </div>

  <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-200">
    <div class="flex items-center gap-2 mb-2">
      <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center">
        <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
      </div>
      <span class="text-xs font-semibold text-slate-500 uppercase">Comercial</span>
    </div>
    <p class="text-lg font-bold text-indigo-600"><%= @resumo[:comercial][:sucesso] %>/<%= @resumo[:comercial][:total] %></p>
  </div>

  <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-200">
    <div class="flex items-center gap-2 mb-2">
      <div class="w-8 h-8 rounded-lg bg-purple-100 flex items-center justify-center">
        <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/></svg>
      </div>
      <span class="text-xs font-semibold text-slate-500 uppercase">Licitações</span>
    </div>
    <p class="text-lg font-bold text-purple-600"><%= @resumo[:licitacoes][:ganhas] %>/<%= @resumo[:licitacoes][:total] %></p>
  </div>

  <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-200">
    <div class="flex items-center gap-2 mb-2">
      <div class="w-8 h-8 rounded-lg bg-rose-100 flex items-center justify-center">
        <svg class="w-4 h-4 text-rose-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <span class="text-xs font-semibold text-slate-500 uppercase">Chamados</span>
    </div>
    <p class="text-lg font-bold text-rose-600"><%= @resumo[:operacoes][:chamados_abertos] %></p>
  </div>
</div>

<!-- Tabs de Navegação -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 mb-6">
  <div class="border-b border-slate-200 overflow-x-auto">
    <nav class="flex -mb-px min-w-max" id="gerencia-tabs">
      <a href="/gerencia?aba=financeiro" class="px-5 py-3.5 text-sm font-medium border-b-2 transition-colors whitespace-nowrap <%= aba == 'financeiro' ? 'border-indigo-500 text-indigo-600 bg-indigo-50/50' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300' %>">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V7m0 1v8m0 0v1"/></svg>
          Financeiro
        </span>
      </a>
      <a href="/gerencia?aba=parceiros" class="px-5 py-3.5 text-sm font-medium border-b-2 transition-colors whitespace-nowrap <%= aba == 'parceiros' ? 'border-blue-500 text-blue-600 bg-blue-50/50' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300' %>">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Credenciamento Parceiros
        </span>
      </a>
      <a href="/gerencia?aba=comercial" class="px-5 py-3.5 text-sm font-medium border-b-2 transition-colors whitespace-nowrap <%= aba == 'comercial' ? 'border-indigo-500 text-indigo-600 bg-indigo-50/50' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300' %>">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          Comercial / Marketing
        </span>
      </a>
      <a href="/gerencia?aba=redes" class="px-5 py-3.5 text-sm font-medium border-b-2 transition-colors whitespace-nowrap <%= aba == 'redes' ? 'border-pink-500 text-pink-600 bg-pink-50/50' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300' %>">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>
          Redes Sociais
        </span>
      </a>
      <a href="/gerencia?aba=licitacoes" class="px-5 py-3.5 text-sm font-medium border-b-2 transition-colors whitespace-nowrap <%= aba == 'licitacoes' ? 'border-purple-500 text-purple-600 bg-purple-50/50' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300' %>">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/></svg>
          Licitações
        </span>
      </a>
      <a href="/gerencia?aba=operacoes" class="px-5 py-3.5 text-sm font-medium border-b-2 transition-colors whitespace-nowrap <%= aba == 'operacoes' ? 'border-rose-500 text-rose-600 bg-rose-50/50' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300' %>">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Operações e Suporte
        </span>
      </a>
    </nav>
  </div>

  <div class="p-6">
    <!-- ==============================
         ABA: FINANCEIRO
    ============================== -->
    <% if aba == 'financeiro' %>

      <!-- RECEBIMENTOS por Frente -->
      <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-slate-800">Recebimentos por Frente</h2>
          <button onclick="document.getElementById('form-recebimento').classList.toggle('hidden')" class="px-4 py-2 bg-emerald-600 text-white rounded-lg text-sm font-medium hover:bg-emerald-700 transition">
            + Novo Recebimento
          </button>
        </div>

        <!-- Form Novo Recebimento -->
        <div id="form-recebimento" class="hidden bg-slate-50 rounded-lg p-5 mb-4 border border-slate-200">
          <form method="POST" action="/gerencia/recebimentos">
            <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Frente *</label>
                <select name="frente" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500">
                  <option value="">Selecione...</option>
                  <option value="manutencao">Manutenção</option>
                  <option value="rastreamento">Rastreamento</option>
                  <option value="combustivel">Combustível</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Descrição</label>
                <input type="text" name="descricao" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Valor (R$) *</label>
                <input type="text" name="valor" required placeholder="0,00" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Data Recebimento</label>
                <input type="date" name="data_recebimento" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500">
              </div>
              <div class="flex items-end">
                <button type="submit" class="w-full px-4 py-2 bg-emerald-600 text-white rounded-lg text-sm font-medium hover:bg-emerald-700 transition">Salvar</button>
              </div>
            </div>
            <div class="mt-3">
              <label class="block text-xs font-semibold text-slate-600 mb-1">Observações</label>
              <input type="text" name="observacoes" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500">
            </div>
          </form>
        </div>

        <!-- Resumo por Frente -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
          <% ['manutencao', 'rastreamento', 'combustivel'].each do |frente| %>
            <% total = @recebimentos.select { |r| r[:frente] == frente }.sum { |r| r[:valor].to_f } %>
            <% qtd = @recebimentos.count { |r| r[:frente] == frente } %>
            <% cor = frente == 'manutencao' ? 'cyan' : (frente == 'rastreamento' ? 'violet' : 'orange') %>
            <% label = frente == 'manutencao' ? 'Manutenção' : (frente == 'rastreamento' ? 'Rastreamento' : 'Combustível') %>
            <div class="bg-<%= cor %>-50 rounded-lg p-4 border border-<%= cor %>-200">
              <p class="text-xs font-semibold text-<%= cor %>-600 uppercase mb-1"><%= label %></p>
              <p class="text-xl font-bold text-<%= cor %>-700"><%= fmt_moeda(total) %></p>
              <p class="text-xs text-<%= cor %>-500 mt-1"><%= qtd %> registro(s)</p>
            </div>
          <% end %>
        </div>

        <!-- Tabela Recebimentos -->
        <% if @recebimentos.any? %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead><tr class="bg-slate-50 text-left">
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Frente</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Descrição</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Valor</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Data</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Ações</th>
              </tr></thead>
              <tbody class="divide-y divide-slate-100">
                <% @recebimentos.each do |r| %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-4 py-3">
                      <% badge_cor = r[:frente] == 'manutencao' ? 'cyan' : (r[:frente] == 'rastreamento' ? 'violet' : 'orange') %>
                      <% badge_label = r[:frente] == 'manutencao' ? 'Manutenção' : (r[:frente] == 'rastreamento' ? 'Rastreamento' : 'Combustível') %>
                      <span class="px-2 py-1 text-xs font-medium rounded-full bg-<%= badge_cor %>-100 text-<%= badge_cor %>-800"><%= badge_label %></span>
                    </td>
                    <td class="px-4 py-3 text-slate-700"><%= r[:descricao] %></td>
                    <td class="px-4 py-3 font-semibold text-emerald-600"><%= fmt_moeda(r[:valor]) %></td>
                    <td class="px-4 py-3 text-slate-500"><%= r[:data_recebimento] ? fmt_data(r[:data_recebimento]) : '-' %></td>
                    <td class="px-4 py-3">
                      <form method="POST" action="/gerencia/recebimentos/<%= r[:id] %>" onsubmit="return confirm('Excluir este recebimento?')">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="text-red-500 hover:text-red-700 text-xs font-medium">Excluir</button>
                      </form>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-slate-400 text-sm text-center py-6">Nenhum recebimento registrado.</p>
        <% end %>
      </div>

      <hr class="my-8 border-slate-200">

      <!-- NF EM ABERTO - CLIENTES -->
      <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-slate-800">Notas Fiscais em Aberto — Clientes</h2>
          <button onclick="document.getElementById('form-nf-cliente').classList.toggle('hidden')" class="px-4 py-2 bg-amber-600 text-white rounded-lg text-sm font-medium hover:bg-amber-700 transition">
            + Nova NF Cliente
          </button>
        </div>

        <div id="form-nf-cliente" class="hidden bg-slate-50 rounded-lg p-5 mb-4 border border-slate-200">
          <form method="POST" action="/gerencia/nf-clientes">
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Nome do Cliente *</label>
                <input type="text" name="nome_cliente" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Centro de Custo</label>
                <input type="text" name="centro_custo" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Período Apurado</label>
                <input type="text" name="periodo_apurado" placeholder="Ex: Mar/2026" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Dt. Vencimento</label>
                <input type="date" name="data_vencimento" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Valor Bruto (R$)</label>
                <input type="text" name="valor_bruto" placeholder="0,00" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Valor Líquido (R$)</label>
                <input type="text" name="valor_liquido" placeholder="0,00" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
              </div>
            </div>
            <div class="mt-3 flex justify-end">
              <button type="submit" class="px-6 py-2 bg-amber-600 text-white rounded-lg text-sm font-medium hover:bg-amber-700 transition">Salvar NF</button>
            </div>
          </form>
        </div>

        <% nf_abertas_cli = @nf_clientes.select { |n| n[:status] == 'aberta' } %>
        <% if nf_abertas_cli.any? %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead><tr class="bg-slate-50 text-left">
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Cliente</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Centro Custo</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Período</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Vencimento</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">V. Bruto</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">V. Líquido</th>
                <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Ações</th>
              </tr></thead>
              <tbody class="divide-y divide-slate-100">
                <% nf_abertas_cli.each do |nf| %>
                  <% vencida = nf[:data_vencimento] && nf[:data_vencimento] < Date.today %>
                  <tr class="hover:bg-slate-50 <%= vencida ? 'bg-red-50' : '' %>">
                    <td class="px-4 py-3 font-medium text-slate-800"><%= nf[:nome_cliente] %></td>
                    <td class="px-4 py-3 text-slate-600"><%= nf[:centro_custo] || '-' %></td>
                    <td class="px-4 py-3 text-slate-600"><%= nf[:periodo_apurado] || '-' %></td>
                    <td class="px-4 py-3 <%= vencida ? 'text-red-600 font-semibold' : 'text-slate-600' %>"><%= nf[:data_vencimento] ? fmt_data(nf[:data_vencimento]) : '-' %></td>
                    <td class="px-4 py-3 font-semibold text-slate-700"><%= fmt_moeda(nf[:valor_bruto]) %></td>
                    <td class="px-4 py-3 font-semibold text-emerald-600"><%= fmt_moeda(nf[:valor_liquido]) %></td>
                    <td class="px-4 py-3 flex gap-2">
                      <form method="POST" action="/gerencia/nf-clientes/<%= nf[:id] %>/pagar" class="inline">
                        <button type="submit" class="text-emerald-600 hover:text-emerald-800 text-xs font-medium" title="Marcar como paga">Pagar</button>
                      </form>
                      <form method="POST" action="/gerencia/nf-clientes/<%= nf[:id] %>" onsubmit="return confirm('Excluir esta NF?')" class="inline">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="text-red-500 hover:text-red-700 text-xs font-medium">Excluir</button>
                      </form>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-slate-400 text-sm text-center py-6">Nenhuma NF de cliente em aberto.</p>
        <% end %>
      </div>

