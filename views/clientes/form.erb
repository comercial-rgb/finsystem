<!-- views/clientes/form.erb - Formulário de cliente (novo/editar) -->

<div class="max-w-2xl mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <a href="/clientes" class="p-2 text-slate-400 hover:text-slate-600 transition">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h1 class="text-2xl font-bold text-slate-800"><%= @cliente[:id] ? 'Editar Cliente' : 'Novo Cliente' %></h1>
  </div>

  <form action="<%= @cliente[:id] ? "/clientes/#{@cliente[:id]}" : '/clientes' %>" method="POST" class="space-y-6">
    <% if @cliente[:id] %>
      <input type="hidden" name="_method" value="PUT">
    <% end %>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
      <h2 class="text-lg font-semibold text-slate-800 mb-4">Dados do Cliente</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-slate-700 mb-1">Nome / Razão Social *</label>
          <input type="text" name="nome" value="<%= @cliente[:nome] %>" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">CNPJ / CPF / EIN</label>
          <input type="text" name="cnpj_cpf_ein" value="<%= @cliente[:cnpj_cpf_ein] %>" placeholder="00.000.000/0001-00" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Tipo</label>
          <select name="tipo" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
            <option value="PJ" <%= @cliente[:tipo] == 'PJ' ? 'selected' : '' %>>Pessoa Jurídica</option>
            <option value="PF" <%= @cliente[:tipo] == 'PF' ? 'selected' : '' %>>Pessoa Física</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Empresa Vinculada</label>
          <select name="empresa_id" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
            <option value="">-- Nenhuma --</option>
            <% @empresas.each do |emp| %>
              <option value="<%= emp[:id] %>" <%= @cliente[:empresa_id].to_s == emp[:id].to_s ? 'selected' : '' %>><%= emp[:nome_fantasia] %></option>
            <% end %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">País</label>
          <select name="pais" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
            <option value="BR" <%= @cliente[:pais] == 'BR' || @cliente[:pais].nil? ? 'selected' : '' %>>Brasil</option>
            <option value="US" <%= @cliente[:pais] == 'US' ? 'selected' : '' %>>Estados Unidos</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" name="email" value="<%= @cliente[:email] %>" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Telefone</label>
          <input type="text" name="telefone" value="<%= @cliente[:telefone] %>" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Cidade</label>
          <input type="text" name="cidade" value="<%= @cliente[:cidade] %>" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Estado</label>
          <input type="text" name="estado" value="<%= @cliente[:estado] %>" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
        </div>
      </div>
    </div>

    <div class="flex justify-end gap-3">
      <a href="/clientes" class="px-6 py-2.5 text-slate-600 bg-white border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50">Cancelar</a>
      <button type="submit" class="px-6 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">
        <%= @cliente[:id] ? 'Atualizar' : 'Cadastrar' %>
      </button>
    </div>
  </form>
</div>
