<!-- views/importacao/index.erb - Upload de extrato bancário -->

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Importar Extrato Bancário</h1>
    <p class="text-slate-500 text-sm mt-1">Faça upload do extrato do banco para alimentar as movimentações automaticamente</p>
  </div>
  <a href="/importacao/limpar-erros" class="px-4 py-2.5 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm font-medium hover:bg-red-100 transition flex items-center gap-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    Limpar importações com erro
  </a>
  <a href="/movimentacoes" class="px-4 py-2.5 bg-slate-100 text-slate-700 rounded-lg text-sm font-medium hover:bg-slate-200 transition flex items-center gap-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    Voltar
  </a>
</div>

<% if session[:flash_error] %>
  <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"><%= session.delete(:flash_error) %></div>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- Formulário de upload -->
  <div class="lg:col-span-2">
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
      <h2 class="text-lg font-semibold text-slate-800 mb-5">Selecionar Arquivo</h2>

      <form method="POST" action="/importacao/processar" enctype="multipart/form-data" class="space-y-5">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Empresa <span class="text-red-500">*</span></label>
            <select name="empresa_id" required
              class="w-full px-3 py-2.5 bg-white border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
              onchange="filtrarContas(this.value)">
              <option value="">Selecione a empresa</option>
              <% @empresas.each do |emp| %>
                <option value="<%= emp[:id] %>"><%= emp[:nome_fantasia] %></option>
              <% end %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Conta Bancária <span class="text-red-500">*</span></label>
            <select name="conta_bancaria_id" id="select-conta" required
              class="w-full px-3 py-2.5 bg-white border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
              <option value="">Selecione primeiro a empresa</option>
              <% @contas.each do |c| %>
                <option value="<%= c[:id] %>" data-empresa="<%= c[:empresa_id] %>" style="display:none">
                  <%= c[:banco] %><%= c[:apelido] ? " — #{c[:apelido]}" : '' %>
                </option>
              <% end %>
            </select>
          </div>
        </div>

        <!-- Área de upload -->
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Arquivo do Extrato <span class="text-red-500">*</span></label>
          <div id="drop-zone"
            class="border-2 border-dashed border-slate-300 rounded-xl p-8 text-center cursor-pointer hover:border-indigo-400 hover:bg-indigo-50/30 transition-all"
            onclick="document.getElementById('arquivo-input').click()"
            ondragover="event.preventDefault(); this.classList.add('border-indigo-500','bg-indigo-50')"
            ondragleave="this.classList.remove('border-indigo-500','bg-indigo-50')"
            ondrop="handleDrop(event)">
            <svg class="w-12 h-12 text-slate-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
            </svg>
            <p class="text-slate-600 font-medium mb-1" id="drop-text">Arraste o arquivo ou clique para selecionar</p>
            <p class="text-slate-400 text-xs">OFX, CSV, XLSX, XLS ou PDF</p>
            <input type="file" id="arquivo-input" name="arquivo" class="hidden"
              accept=".ofx,.ofc,.csv,.xlsx,.xls,.pdf"
              onchange="showFileName(this)">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Categoria Padrão (opcional)</label>
          <select name="categoria_id"
            class="w-full px-3 py-2.5 bg-white border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="">Sem categoria (definir na revisão)</option>
            <% @categorias.each do |cat| %>
              <option value="<%= cat[:id] %>"><%= cat[:nome] %></option>
            <% end %>
          </select>
          <p class="text-xs text-slate-400 mt-1">Será aplicada em todas as transações. Você pode alterar individualmente na próxima tela.</p>
        </div>

        <button type="submit"
          class="w-full py-3 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          Processar e Revisar Transações
        </button>
      </form>
    </div>
  </div>

  <!-- Painel de instruções -->
  <div class="space-y-4">
    <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-5">
      <h3 class="font-semibold text-indigo-800 mb-3 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Formatos suportados
      </h3>
      <ul class="space-y-2 text-sm text-indigo-700">
        <li class="flex items-start gap-2">
          <span class="font-mono bg-indigo-100 px-1.5 py-0.5 rounded text-xs font-bold mt-0.5">.OFX</span>
          <span>Padrão Febraban — exportado pela maioria dos bancos BR (Sicredi, Itaú, Bradesco, BB, Caixa, Santander)</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="font-mono bg-indigo-100 px-1.5 py-0.5 rounded text-xs font-bold mt-0.5">.CSV</span>
          <span>Nubank, Inter, C6, XP, planilhas exportadas</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="font-mono bg-indigo-100 px-1.5 py-0.5 rounded text-xs font-bold mt-0.5">.XLSX</span>
          <span>Excel — Bradesco, Itaú, BB</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="font-mono bg-indigo-100 px-1.5 py-0.5 rounded text-xs font-bold mt-0.5">.PDF</span>
          <span>Extratos em PDF (melhor esforço — pode requerer ajustes)</span>
        </li>
      </ul>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-xl p-5">
      <h3 class="font-semibold text-amber-800 mb-2 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        Como funciona
      </h3>
      <ol class="space-y-1.5 text-sm text-amber-700 list-decimal list-inside">
        <li>Faça upload do extrato</li>
        <li>Revise as transações identificadas</li>
        <li>Desmarque as que não deseja importar</li>
        <li>Confirme — as movimentações são criadas automaticamente</li>
      </ol>
      <p class="text-xs text-amber-600 mt-3">Duplicatas potenciais são destacadas automaticamente.</p>
    </div>
  </div>

</div>

<script>
function filtrarContas(empresaId) {
  const select = document.getElementById('select-conta');
  select.value = '';
  Array.from(select.options).forEach(opt => {
    if (!opt.value) { opt.style.display = ''; return; }
    opt.style.display = opt.dataset.empresa === empresaId ? '' : 'none';
  });
  select.options[0].text = empresaId ? 'Selecione a conta' : 'Selecione primeiro a empresa';
}

function showFileName(input) {
  const name = input.files[0]?.name;
  if (name) document.getElementById('drop-text').textContent = name;
}

function handleDrop(e) {
  e.preventDefault();
  const zone = document.getElementById('drop-zone');
  zone.classList.remove('border-indigo-500', 'bg-indigo-50');
  const file = e.dataTransfer.files[0];
  if (!file) return;
  const input = document.getElementById('arquivo-input');
  const dt = new DataTransfer();
  dt.items.add(file);
  input.files = dt.files;
  document.getElementById('drop-text').textContent = file.name;
}
</script>
