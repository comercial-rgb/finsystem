<!-- views/importacao/reset_completo.erb -->

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Reset Completo</h1>
    <p class="text-slate-500 text-sm mt-1">Apagar todas as movimentações e recomeçar do zero</p>
  </div>
  <a href="/importacao" class="px-4 py-2.5 bg-slate-100 text-slate-700 rounded-lg text-sm font-medium hover:bg-slate-200 transition flex items-center gap-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    Cancelar
  </a>
</div>

<% if session[:flash_error] %>
  <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"><%= session.delete(:flash_error) %></div>
<% end %>

<div class="max-w-2xl mx-auto">

  <!-- O que será apagado -->
  <div class="bg-red-50 border border-red-300 rounded-xl p-6 mb-6">
    <div class="flex items-start gap-4">
      <svg class="w-8 h-8 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      <div>
        <h2 class="text-lg font-bold text-red-800 mb-2">Esta ação é irreversível</h2>
        <p class="text-red-700 text-sm mb-4">O seguinte será excluído permanentemente:</p>
        <ul class="space-y-2 text-sm text-red-700">
          <li class="flex items-center gap-2">
            <span class="w-2 h-2 bg-red-500 rounded-full flex-shrink-0"></span>
            <strong><%= @total_movs %></strong> movimentações (receitas, despesas, transferências)
          </li>
          <li class="flex items-center gap-2">
            <span class="w-2 h-2 bg-red-500 rounded-full flex-shrink-0"></span>
            <strong><%= @total_transferencias %></strong> registros de transferência entre contas
          </li>
          <li class="flex items-center gap-2">
            <span class="w-2 h-2 bg-red-500 rounded-full flex-shrink-0"></span>
            Histórico de saldos e comprovantes vinculados
          </li>
          <li class="flex items-center gap-2">
            <span class="w-2 h-2 bg-red-500 rounded-full flex-shrink-0"></span>
            Saldos das contas serão redefinidos ao valor inicial cadastrado
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- O que será mantido -->
  <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-5 mb-6">
    <h3 class="font-semibold text-emerald-800 mb-2 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      O que será mantido
    </h3>
    <ul class="text-sm text-emerald-700 space-y-1">
      <li>Empresas, contas bancárias e configurações</li>
      <li>Clientes, fornecedores e categorias</li>
      <li>Usuários e permissões</li>
      <li>Cartões de crédito e financeiro pessoal</li>
    </ul>
  </div>

  <!-- Saldos iniciais das contas -->
  <% if @contas.any? %>
  <div class="bg-white rounded-xl border border-slate-200 p-5 mb-6">
    <h3 class="font-semibold text-slate-700 mb-3 text-sm">Saldos que serão restaurados</h3>
    <div class="space-y-2">
      <% @contas.each do |c| %>
        <div class="flex justify-between items-center text-sm">
          <span class="text-slate-600"><%= c[:banco] %><%= c[:apelido] ? " — #{c[:apelido]}" : '' %> <span class="text-slate-400 text-xs">(<%= c[:empresa_nome] %>)</span></span>
          <span class="font-semibold text-slate-800"><%= fmt_moeda(c[:saldo_inicial] || 0) %></span>
        </div>
      <% end %>
    </div>
    <p class="text-xs text-slate-400 mt-3">Para alterar os saldos iniciais, edite as contas em Empresas antes de confirmar.</p>
  </div>
  <% end %>

  <!-- Confirmação -->
  <div class="bg-white rounded-xl border border-slate-200 p-6">
    <h3 class="font-semibold text-slate-800 mb-4">Confirmar reset</h3>
    <form method="POST" action="/importacao/reset-completo/confirmar">
      <div class="mb-4">
        <label class="block text-sm text-slate-600 mb-2">
          Digite <strong class="text-red-600 font-mono">CONFIRMAR RESET</strong> para prosseguir:
        </label>
        <input type="text" name="confirmacao" placeholder="CONFIRMAR RESET"
          class="w-full px-4 py-3 border-2 border-slate-300 rounded-lg text-sm font-mono focus:outline-none focus:border-red-400"
          autocomplete="off">
      </div>
      <button type="submit"
        class="w-full py-3 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700 transition flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Apagar tudo e recomeçar do zero
      </button>
    </form>
  </div>

</div>
