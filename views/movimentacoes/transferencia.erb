<!-- views/movimentacoes/transferencia.erb - Transferência entre contas -->

<div class="max-w-4xl mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <a href="/movimentacoes" class="p-2 text-slate-400 hover:text-slate-600 transition">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <div>
      <h1 class="text-2xl font-bold text-slate-800">Transferência entre Contas</h1>
      <p class="text-slate-500 text-sm mt-1">Transfira valores entre contas bancárias das empresas</p>
    </div>
  </div>

  <!-- Formulário de Transferência -->
  <form action="/movimentacoes/transferencia" method="POST" class="space-y-6">

    <!-- Conta Origem e Destino -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
      <h2 class="font-semibold text-slate-800 mb-4">Contas</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Conta de Origem *</label>
          <select name="conta_origem_id" required id="conta_origem" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500" onchange="validarContas()">
            <option value="">-- Selecione a conta de saída --</option>
            <% @contas.each do |c| %>
              <option value="<%= c[:id] %>" data-moeda="<%= c[:moeda] || 'BRL' %>">
                <%= c[:banco] %> (<%= c[:apelido] %>) - <%= c[:empresa_nome] %> [<%= c[:moeda] || 'BRL' %>]
              </option>
            <% end %>
          </select>
          <p class="text-xs text-slate-400 mt-1">De onde o valor vai sair</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Conta de Destino *</label>
          <select name="conta_destino_id" required id="conta_destino" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500" onchange="validarContas()">
            <option value="">-- Selecione a conta de entrada --</option>
            <% @contas.each do |c| %>
              <option value="<%= c[:id] %>" data-moeda="<%= c[:moeda] || 'BRL' %>">
                <%= c[:banco] %> (<%= c[:apelido] %>) - <%= c[:empresa_nome] %> [<%= c[:moeda] || 'BRL' %>]
              </option>
            <% end %>
          </select>
          <p class="text-xs text-slate-400 mt-1">Para onde o valor vai entrar</p>
        </div>
      </div>

      <div id="alerta-mesma-conta" class="hidden mt-4 bg-red-50 border border-red-200 rounded-lg p-3">
        <p class="text-sm text-red-700 font-medium">⚠️ As contas de origem e destino devem ser diferentes!</p>
      </div>
    </div>

    <!-- Valor e Data -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
      <h2 class="font-semibold text-slate-800 mb-4">Detalhes da Transferência</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Valor *</label>
          <input type="text" name="valor" required placeholder="0,00"
                 class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm moeda-br">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Data *</label>
          <input type="date" name="data_transferencia" value="<%= hoje %>" required
                 class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Descrição</label>
          <input type="text" name="descricao" placeholder="Ex: Transferência para capital de giro"
                 class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
        </div>
      </div>

      <div class="mt-4">
        <label class="block text-sm font-medium text-slate-700 mb-1">Observações</label>
        <textarea name="observacoes" rows="2" placeholder="Detalhes adicionais..."
                  class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm"></textarea>
      </div>
    </div>

    <!-- Resumo Visual -->
    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl border border-blue-200 p-6">
      <div class="flex items-center justify-center gap-4">
        <div class="text-center">
          <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-2">
            <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7"/></svg>
          </div>
          <p class="text-xs text-slate-500 font-medium">Saída</p>
          <p class="text-sm font-bold text-red-600" id="resumo-origem">Selecione...</p>
        </div>
        <div class="flex-shrink-0">
          <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-2">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h14"/></svg>
          </div>
          <p class="text-xs text-slate-500 font-medium">Entrada</p>
          <p class="text-sm font-bold text-emerald-600" id="resumo-destino">Selecione...</p>
        </div>
      </div>
    </div>

    <!-- Submit -->
    <div class="flex justify-end gap-3">
      <a href="/movimentacoes" class="px-6 py-2.5 text-slate-600 bg-white border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50 transition">
        Cancelar
      </a>
      <button type="submit" id="btn-transferir" class="px-6 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
        Realizar Transferência
      </button>
    </div>
  </form>

  <!-- Últimas Transferências -->
  <% if @transferencias && !@transferencias.empty? %>
    <div class="mt-10">
      <h2 class="text-lg font-bold text-slate-800 mb-4">Últimas Transferências</h2>
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50">
                <th class="px-4 py-3">Data</th>
                <th class="px-4 py-3">Origem</th>
                <th class="px-4 py-3 text-center">→</th>
                <th class="px-4 py-3">Destino</th>
                <th class="px-4 py-3 text-right">Valor</th>
                <th class="px-4 py-3">Descrição</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% @transferencias.each do |t| %>
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 text-slate-600 whitespace-nowrap"><%= fmt_data(t[:data_transferencia]) %></td>
                  <td class="px-4 py-3">
                    <span class="font-medium text-slate-800"><%= t[:banco_origem] %></span>
                    <span class="text-xs text-slate-500">(<%= t[:apelido_origem] %>)</span>
                    <div class="text-xs text-slate-400"><%= t[:empresa_origem] %></div>
                  </td>
                  <td class="px-4 py-3 text-center text-indigo-400">→</td>
                  <td class="px-4 py-3">
                    <span class="font-medium text-slate-800"><%= t[:banco_destino] %></span>
                    <span class="text-xs text-slate-500">(<%= t[:apelido_destino] %>)</span>
                    <div class="text-xs text-slate-400"><%= t[:empresa_destino] %></div>
                  </td>
                  <td class="px-4 py-3 text-right font-bold text-indigo-600 whitespace-nowrap"><%= fmt_moeda(t[:valor]) %></td>
                  <td class="px-4 py-3 text-slate-600 text-xs"><%= t[:descricao] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
function validarContas() {
  var origem = document.getElementById('conta_origem');
  var destino = document.getElementById('conta_destino');
  var alerta = document.getElementById('alerta-mesma-conta');
  var btn = document.getElementById('btn-transferir');
  var resumoOrigem = document.getElementById('resumo-origem');
  var resumoDestino = document.getElementById('resumo-destino');

  if (origem.value) {
    resumoOrigem.textContent = origem.options[origem.selectedIndex].text;
  }
  if (destino.value) {
    resumoDestino.textContent = destino.options[destino.selectedIndex].text;
  }

  if (origem.value && destino.value && origem.value === destino.value) {
    alerta.classList.remove('hidden');
    btn.disabled = true;
    btn.classList.add('opacity-50', 'cursor-not-allowed');
  } else {
    alerta.classList.add('hidden');
    btn.disabled = false;
    btn.classList.remove('opacity-50', 'cursor-not-allowed');
  }
}
</script>
