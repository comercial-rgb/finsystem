<!-- views/movimentacoes/index.erb - Listagem de movimentações -->

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Movimentações</h1>
    <p class="text-slate-500 text-sm mt-1"><%= nome_mes(@mes) %>/<%= @ano %></p>
  </div>
  <div class="flex flex-wrap gap-2">
    <a href="/importacao" class="px-4 py-2.5 bg-teal-600 text-white rounded-lg text-sm font-medium hover:bg-teal-700 transition flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
      Importar Extrato
    </a>
    <a href="/movimentacoes/transferencia" class="px-4 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
      Transferência
    </a>
    <a href="/movimentacoes/nova" class="px-4 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Nova Movimentação
    </a>
  </div>
</div>

<!-- Filtros -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 mb-6">
  <form method="GET" action="/movimentacoes" class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-3">
    <div class="lg:col-span-2">
      <input type="text" name="busca" value="<%= @busca %>" placeholder="Buscar por descrição..." class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
    </div>
    <select name="empresa_id" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <option value="">Todas Empresas</option>
      <% @empresas.each do |emp| %>
        <option value="<%= emp[:id] %>" <%= @empresa_id.to_s == emp[:id].to_s ? 'selected' : '' %>><%= emp[:nome_fantasia] %></option>
      <% end %>
    </select>
    <select name="tipo" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <option value="">Todos Tipos</option>
      <option value="receita" <%= @tipo == 'receita' ? 'selected' : '' %>>Receitas</option>
      <option value="despesa" <%= @tipo == 'despesa' ? 'selected' : '' %>>Despesas</option>
    </select>
    <select name="conta_bancaria_id" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <option value="">Todos Bancos</option>
      <% @contas.each do |c| %>
        <option value="<%= c[:id] %>" <%= @conta_bancaria_id.to_s == c[:id].to_s ? 'selected' : '' %>><%= c[:banco] %> - <%= c[:empresa_nome] %></option>
      <% end %>
    </select>
    <select name="status" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <option value="">Todos Status</option>
      <option value="confirmado" <%= @status == 'confirmado' ? 'selected' : '' %>>Confirmado</option>
      <option value="pendente" <%= @status == 'pendente' ? 'selected' : '' %>>Pendente</option>
      <option value="conciliado" <%= @status == 'conciliado' ? 'selected' : '' %>>Conciliado</option>      <option value=\"transferencia\" <%= @status == 'transferencia' ? 'selected' : '' %>>Transferência</option>    </select>
    <select name="mes" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <% meses_select.each do |num, nome| %>
        <option value="<%= num %>" <%= @mes == num ? 'selected' : '' %>><%= nome %></option>
      <% end %>
    </select>
    <select name="ano" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
      <% anos_select.each do |a| %>
        <option value="<%= a %>" <%= @ano == a ? 'selected' : '' %>><%= a %></option>
      <% end %>
    </select>
    <button type="submit" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition">Filtrar</button>
  </form>
</div>

<!-- Resumo do filtro -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="bg-emerald-50 rounded-xl p-4 border border-emerald-200">
    <p class="text-xs text-emerald-600 font-semibold uppercase">Total Receitas</p>
    <p class="text-xl font-bold text-emerald-700 mt-1"><%= fmt_moeda(@total_receitas) %></p>
  </div>
  <div class="bg-red-50 rounded-xl p-4 border border-red-200">
    <p class="text-xs text-red-600 font-semibold uppercase">Total Despesas</p>
    <p class="text-xl font-bold text-red-700 mt-1"><%= fmt_moeda(@total_despesas) %></p>
  </div>
  <div class="<%= @saldo_periodo >= 0 ? 'bg-blue-50 border-blue-200' : 'bg-orange-50 border-orange-200' %> rounded-xl p-4 border">
    <p class="text-xs <%= @saldo_periodo >= 0 ? 'text-blue-600' : 'text-orange-600' %> font-semibold uppercase">Saldo do Período</p>
    <p class="text-xl font-bold <%= @saldo_periodo >= 0 ? 'text-blue-700' : 'text-orange-700' %> mt-1"><%= fmt_moeda(@saldo_periodo) %></p>
  </div>
</div>

<!-- Tabela -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50">
          <th class="px-4 py-3">Data</th>
          <th class="px-4 py-3">Tipo</th>
          <th class="px-4 py-3">Descrição</th>
          <th class="px-4 py-3">Categoria</th>
          <th class="px-4 py-3">Cliente/Fornecedor</th>
          <th class="px-4 py-3">Empresa</th>
          <th class="px-4 py-3">Banco</th>
          <th class="px-4 py-3 text-right">Valor</th>
          <th class="px-4 py-3 text-right">Lucro</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3 text-center">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @movimentacoes.each do |m| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-4 py-3 text-slate-600 whitespace-nowrap"><%= fmt_data(m[:data_movimentacao]) %></td>
            <td class="px-4 py-3"><%= badge_tipo(m[:tipo]) %></td>
            <td class="px-4 py-3">
              <div class="font-medium text-slate-800 max-w-[200px] truncate"><%= m[:descricao] %></div>
              <% if m[:is_antecipacao] %>
                <span class="text-xs text-purple-600 font-medium">⚡ Antecipação</span>
              <% end %>
              <% if m[:numero_documento] %>
                <div class="text-xs text-slate-400">Doc: <%= m[:numero_documento] %></div>
              <% end %>
            </td>
            <td class="px-4 py-3 cursor-pointer group" onclick="abrirInline(this, 'categoria', <%= m[:id] %>)" title="Clique para editar categoria">
              <span class="inline-flex items-center gap-1 categoria-display-<%= m[:id] %>">
                <% if m[:categoria_nome] %>
                  <span class="w-2 h-2 rounded-full flex-shrink-0" style="background-color: <%= m[:categoria_cor] || '#94a3b8' %>"></span>
                  <span class="text-slate-600 text-xs"><%= m[:categoria_nome] %></span>
                <% else %>
                  <span class="text-slate-300 text-xs group-hover:text-slate-400">+ categoria</span>
                <% end %>
              </span>
            </td>
            <td class="px-4 py-3 cursor-pointer group" onclick="abrirInline(this, 'parte', <%= m[:id] %>)" title="Clique para editar cliente/fornecedor/sócio">
              <span class="parte-display-<%= m[:id] %> text-slate-600 text-xs">
                <% if m[:socio_nome] %>
                  <span class="text-purple-600 font-medium">👤 <%= m[:socio_nome] %> (<%= m[:socio_percentual] %>%)</span>
                <% elsif m[:cliente_nome] %>
                  <%= m[:cliente_nome] %>
                <% elsif m[:fornecedor_nome] %>
                  <%= m[:fornecedor_nome] %>
                <% else %>
                  <span class="text-slate-300 group-hover:text-slate-400">+ vincular</span>
                <% end %>
              </span>
            </td>
            <td class="px-4 py-3 text-slate-600 text-xs"><%= m[:empresa_nome] %></td>
            <td class="px-4 py-3 text-slate-600 text-xs"><%= m[:banco_nome] %></td>
            <td class="px-4 py-3 text-right font-bold <%= cor_valor(m[:tipo]) %> whitespace-nowrap">
              <%= prefixo_valor(m[:tipo]) %> <%= fmt_moeda(m[:valor_bruto]) %>
            </td>
            <td class="px-4 py-3 text-right text-sm">
              <% if m[:lucro] && m[:lucro] > 0 %>
                <span class="text-emerald-600 font-medium"><%= fmt_moeda(m[:lucro]) %></span>
              <% else %>
                <span class="text-slate-300">-</span>
              <% end %>
            </td>
            <td class="px-4 py-3"><%= badge_status(m[:status]) %></td>
            <td class="px-4 py-3 text-center">
              <div class="flex items-center justify-center gap-1">
                <button onclick="showDetalheModal(<%= m[:id] %>)" class="p-1.5 text-slate-400 hover:text-cyan-600 transition" title="Detalhes">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                </button>
                <a href="/movimentacoes/<%= m[:id] %>/editar" class="p-1.5 text-slate-400 hover:text-indigo-600 transition" title="Editar">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                </a>
                <% if m[:status] == 'pendente' %>
                  <form action="/movimentacoes/<%= m[:id] %>/confirmar" method="POST" class="inline" title="Confirmar e atualizar saldo">
                    <button type="submit" class="p-1.5 text-amber-500 hover:text-emerald-600 transition" title="Confirmar">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    </button>
                  </form>
                <% end %>
                <% unless m[:conciliado] %>
                  <form action="/movimentacoes/<%= m[:id] %>/conciliar" method="POST" class="inline">
                    <button type="submit" class="p-1.5 text-slate-400 hover:text-blue-600 transition" title="Conciliar">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </button>
                  </form>
                <% end %>
                <% if m[:tipo_operacao] != 'transferencia' && m[:status] != 'transferencia' %>
                  <button onclick="abrirModalTransferencia(<%= m[:id] %>, '<%= m[:conta_bancaria_id] %>', '<%= (m[:valor_bruto].to_f rescue 0).round(2) %>')"
                    class="p-1.5 text-slate-400 hover:text-teal-600 transition" title="Converter para transferência">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                  </button>
                <% end %>
                <form action="/movimentacoes/<%= m[:id] %>" method="POST" class="inline" onsubmit="return confirm('Tem certeza que deseja excluir esta movimentação?')">
                  <input type="hidden" name="_method" value="DELETE">
                  <button type="submit" class="p-1.5 text-slate-400 hover:text-red-600 transition" title="Excluir">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% if @movimentacoes.empty? %>
    <div class="text-center py-12">
      <p class="text-slate-400 text-sm">Nenhuma movimentação encontrada com estes filtros</p>
    </div>
  <% end %>

  <!-- Paginação + Export -->
  <div class="px-5 py-3 border-t border-slate-100 flex flex-wrap justify-between items-center bg-slate-50 gap-3">
    <span class="text-xs text-slate-500"><%= @total_registros %> movimentações (página <%= @page %> de <%= @total_pages %>)</span>
    <div class="flex items-center gap-2">
      <% if @total_pages > 1 %>
        <% if @page > 1 %>
          <a href="/movimentacoes?page=<%= @page - 1 %>&mes=<%= @mes %>&ano=<%= @ano %>&empresa_id=<%= @empresa_id %>&tipo=<%= @tipo %>&conta_bancaria_id=<%= @conta_bancaria_id %>&status=<%= @status %>&busca=<%= @busca %>" class="px-3 py-1 text-xs bg-white border border-slate-300 rounded hover:bg-slate-50">&laquo; Anterior</a>
        <% end %>
        <% (1..@total_pages).each do |p| %>
          <% if p == @page %>
            <span class="px-3 py-1 text-xs bg-indigo-600 text-white rounded"><%= p %></span>
          <% elsif (p - @page).abs <= 2 || p == 1 || p == @total_pages %>
            <a href="/movimentacoes?page=<%= p %>&mes=<%= @mes %>&ano=<%= @ano %>&empresa_id=<%= @empresa_id %>&tipo=<%= @tipo %>&conta_bancaria_id=<%= @conta_bancaria_id %>&status=<%= @status %>&busca=<%= @busca %>" class="px-3 py-1 text-xs bg-white border border-slate-300 rounded hover:bg-slate-50"><%= p %></a>
          <% elsif (p - @page).abs == 3 %>
            <span class="text-xs text-slate-400">...</span>
          <% end %>
        <% end %>
        <% if @page < @total_pages %>
          <a href="/movimentacoes?page=<%= @page + 1 %>&mes=<%= @mes %>&ano=<%= @ano %>&empresa_id=<%= @empresa_id %>&tipo=<%= @tipo %>&conta_bancaria_id=<%= @conta_bancaria_id %>&status=<%= @status %>&busca=<%= @busca %>" class="px-3 py-1 text-xs bg-white border border-slate-300 rounded hover:bg-slate-50">Próxima &raquo;</a>
        <% end %>
      <% end %>
      <a href="/relatorios/exportar_csv?mes=<%= @mes %>&ano=<%= @ano %>&empresa_id=<%= @empresa_id %>&conta_bancaria_id=<%= @conta_bancaria_id %>"
         class="text-xs text-indigo-600 hover:text-indigo-700 font-medium flex items-center gap-1 ml-3">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
        Exportar CSV
      </a>
    </div>
  </div>
</div>

<!-- Modal Converter para Transferência -->
<div id="modal-transferencia" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
  <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full mx-4">
    <div class="p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold text-slate-800">Converter para Transferência</h3>
        <button onclick="fecharModalTransferencia()" class="p-1 text-slate-400 hover:text-slate-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <div class="bg-teal-50 border border-teal-200 rounded-lg p-3 mb-4 text-sm text-teal-700">
        A movimentação de saída será convertida para transferência e a <strong>entrada correspondente será criada automaticamente</strong> na conta de destino. Os saldos de ambas as contas serão recalculados.
      </div>

      <form method="POST" id="form-converter-transferencia" action="">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Valor da transferência</label>
            <p id="modal-transf-valor" class="text-xl font-bold text-slate-800"></p>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Conta de destino <span class="text-red-500">*</span></label>
            <select name="conta_destino_id" id="modal-transf-conta-destino" required
              class="w-full px-3 py-2.5 bg-white border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500">
              <option value="">Selecione a conta que recebeu</option>
              <% @contas.each do |c| %>
                <option value="<%= c[:id] %>" data-conta-id="<%= c[:id] %>">
                  <%= c[:banco] %><%= c[:apelido] ? " — #{c[:apelido]}" : '' %> (<%= c[:empresa_nome] %>)
                </option>
              <% end %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Descrição (opcional)</label>
            <input type="text" name="descricao" placeholder="Ex: TED Sicredi — Caixa operacional"
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500">
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="fecharModalTransferencia()"
            class="px-5 py-2.5 bg-slate-100 text-slate-700 rounded-lg text-sm font-medium hover:bg-slate-200 transition">
            Cancelar
          </button>
          <button type="submit"
            class="px-5 py-2.5 bg-teal-600 text-white rounded-lg text-sm font-medium hover:bg-teal-700 transition flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
            Converter e criar entrada
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Detalhes -->
<div id="detalhe-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
  <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full mx-4 max-h-[90vh] overflow-y-auto">
    <div class="p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold text-slate-800">Detalhes da Movimentação</h3>
        <button onclick="closeDetalheModal()" class="p-1 text-slate-400 hover:text-slate-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="detalhe-content" class="space-y-3">
        <p class="text-sm text-slate-400">Carregando...</p>
      </div>
    </div>
  </div>
</div>

<!-- Dados inline para selects -->
<script>
var _categorias = [
  <% @categorias.each do |c| %>
  { id: <%= c[:id] %>, nome: "<%= c[:nome].gsub('"','\"') %>", cor: "<%= c[:cor] || '#94a3b8' %>", tipo: "<%= c[:tipo] %>" },
  <% end %>
];
var _clientes = [
  <% @clientes.each do |c| %>
  { id: <%= c[:id] %>, nome: "<%= c[:nome].gsub('"','\"') %>" },
  <% end %>
];
var _fornecedores = [
  <% @fornecedores.each do |f| %>
  { id: <%= f[:id] %>, nome: "<%= f[:nome].gsub('"','\"') %>" },
  <% end %>
];
var _socios = [
  <% @socios.each do |s| %>
  { id: <%= s[:id] %>, nome: "<%= s[:nome].gsub('"','\"') %>", percentual: "<%= s[:percentual_participacao] %>" },
  <% end %>
];

var _inlineAtivo = null;

function abrirInline(cell, tipo, movId) {
  // Fechar inline anterior sem salvar
  if (_inlineAtivo) fecharInline(_inlineAtivo, false);

  var select = document.createElement('select');
  select.className = 'text-xs border border-indigo-400 rounded px-1.5 py-1 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-400 min-w-[140px] max-w-[200px]';
  select.innerHTML = '<option value="">— remover —</option>';

  if (tipo === 'categoria') {
    var grupos = {};
    _categorias.forEach(function(c) {
      if (!grupos[c.tipo]) grupos[c.tipo] = [];
      grupos[c.tipo].push(c);
    });
    Object.keys(grupos).forEach(function(t) {
      var og = document.createElement('optgroup');
      og.label = t === 'receita' ? 'Receitas' : 'Despesas';
      grupos[t].forEach(function(c) {
        var o = new Option(c.nome, c.id);
        og.appendChild(o);
      });
      select.appendChild(og);
    });
  } else {
    // Parte: cliente, fornecedor ou sócio
    var ogCli = document.createElement('optgroup'); ogCli.label = 'Clientes';
    _clientes.forEach(function(c) { ogCli.appendChild(new Option(c.nome, 'cli_' + c.id)); });
    var ogForn = document.createElement('optgroup'); ogForn.label = 'Fornecedores';
    _fornecedores.forEach(function(f) { ogForn.appendChild(new Option(f.nome, 'forn_' + f.id)); });
    var ogSoc = document.createElement('optgroup'); ogSoc.label = 'Sócios';
    _socios.forEach(function(s) { ogSoc.appendChild(new Option('👤 ' + s.nome + ' (' + s.percentual + '%)', 'soc_' + s.id)); });
    select.appendChild(ogCli);
    select.appendChild(ogForn);
    select.appendChild(ogSoc);
  }

  _inlineAtivo = { cell: cell, tipo: tipo, movId: movId, select: select };

  // Ocultar conteúdo atual e mostrar select
  cell.querySelectorAll('span').forEach(function(s) { s.style.display = 'none'; });
  cell.appendChild(select);
  select.focus();

  select.addEventListener('change', function() { salvarInline(_inlineAtivo); });
  select.addEventListener('blur',   function() { setTimeout(function() { fecharInline(_inlineAtivo, false); }, 200); });
  select.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') fecharInline(_inlineAtivo, false);
  });
}

function fecharInline(ctx, restaurar) {
  if (!ctx) return;
  if (ctx.select && ctx.select.parentNode) ctx.select.parentNode.removeChild(ctx.select);
  ctx.cell.querySelectorAll('span').forEach(function(s) { s.style.display = ''; });
  _inlineAtivo = null;
}

function salvarInline(ctx) {
  var val = ctx.select.value;
  var body = {};

  if (ctx.tipo === 'categoria') {
    body.categoria_id = val;
  } else {
    // Limpar todos os campos de parte antes de definir o novo
    body.cliente_id    = '';
    body.fornecedor_id = '';
    body.socio_id      = '';
    if (val.startsWith('cli_'))  body.cliente_id    = val.replace('cli_', '');
    if (val.startsWith('forn_')) body.fornecedor_id = val.replace('forn_', '');
    if (val.startsWith('soc_'))  body.socio_id      = val.replace('soc_', '');
  }

  // Feedback visual de loading
  ctx.select.disabled = true;
  ctx.select.style.opacity = '0.5';

  var fd = new FormData();
  Object.keys(body).forEach(function(k) { fd.append(k, body[k]); });

  fetch('/movimentacoes/' + ctx.movId + '/quick-update', { method: 'POST', body: fd })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.ok) { fecharInline(ctx, false); return; }

      if (ctx.tipo === 'categoria') {
        var span = ctx.cell.querySelector('.categoria-display-' + ctx.movId);
        if (!span) { span = document.createElement('span'); span.className = 'categoria-display-' + ctx.movId + ' inline-flex items-center gap-1'; ctx.cell.appendChild(span); }
        if (data.categoria_nome) {
          span.innerHTML = '<span class="w-2 h-2 rounded-full flex-shrink-0" style="background-color:' + data.categoria_cor + '"></span><span class="text-slate-600 text-xs">' + data.categoria_nome + '</span>';
        } else {
          span.innerHTML = '<span class="text-slate-300 text-xs group-hover:text-slate-400">+ categoria</span>';
        }
      } else {
        var span = ctx.cell.querySelector('.parte-display-' + ctx.movId);
        if (!span) { span = document.createElement('span'); span.className = 'parte-display-' + ctx.movId + ' text-slate-600 text-xs'; ctx.cell.appendChild(span); }
        if (data.socio_nome) {
          span.innerHTML = '<span class="text-purple-600 font-medium">👤 ' + data.socio_nome + ' (' + data.socio_percentual + '%)</span>';
        } else if (data.cliente_nome) {
          span.innerHTML = data.cliente_nome;
          span.className = 'parte-display-' + ctx.movId + ' text-slate-600 text-xs';
        } else if (data.fornecedor_nome) {
          span.innerHTML = data.fornecedor_nome;
          span.className = 'parte-display-' + ctx.movId + ' text-slate-600 text-xs';
        } else {
          span.innerHTML = '<span class="text-slate-300 group-hover:text-slate-400">+ vincular</span>';
        }
      }

      fecharInline(ctx, false);

      // Flash de sucesso na célula
      ctx.cell.style.background = '#d1fae5';
      setTimeout(function() { ctx.cell.style.background = ''; }, 800);
    })
    .catch(function() { fecharInline(ctx, false); });
}

// Fechar ao clicar fora
document.addEventListener('click', function(e) {
  if (_inlineAtivo && !_inlineAtivo.cell.contains(e.target)) {
    fecharInline(_inlineAtivo, false);
  }
});
</script>

<script>
var movData = {};
<% @movimentacoes.each do |m| %>
movData[<%= m[:id] %>] = {
  id: <%= m[:id] %>,
  tipo: '<%= m[:tipo] %>',
  descricao: '<%= m[:descricao]&.gsub("'", "\\\\'") %>',
  data: '<%= fmt_data(m[:data_movimentacao]) %>',
  valor: '<%= fmt_moeda(m[:valor_bruto]) %>',
  lucro: '<%= m[:lucro] && m[:lucro] > 0 ? fmt_moeda(m[:lucro]) : "-" %>',
  status: '<%= m[:status] %>',
  categoria: '<%= m[:categoria_nome] || "-" %>',
  empresa: '<%= m[:empresa_nome] || "-" %>',
  banco: '<%= m[:banco_nome] || "-" %>',
  cliente: '<%= m[:cliente_nome] || "-" %>',
  fornecedor: '<%= m[:fornecedor_nome] || "-" %>',
  tipo_operacao: '<%= m[:tipo_operacao]&.gsub("_", " ")&.capitalize || "-" %>',
  forma_pagamento: '<%= m[:forma_pagamento]&.gsub("_", " ")&.capitalize || "-" %>',
  numero_documento: '<%= m[:numero_documento] || "-" %>',
  observacoes: '<%= m[:observacoes]&.gsub("'", "\\\\'")&.gsub("\n", " ") || "-" %>',
  conciliado: <%= m[:conciliado] ? 'true' : 'false' %>,
  tipo_cobranca: '<%= m[:tipo_cobranca] || "unica" %>',
  parcela: '<%= m[:parcela_atual] %>/<%= m[:total_parcelas] %>',
  socio_nome: '<%= m[:socio_nome] || "" %>',
  socio_percentual: '<%= m[:socio_percentual] || "" %>'
};
<% end %>

function showDetalheModal(id) {
  var m = movData[id];
  if (!m) return;
  var tipoClass = m.tipo === 'receita' ? 'text-emerald-600' : 'text-red-600';
  var tipoPrefix = m.tipo === 'receita' ? '+' : '-';
  var html = '<div class="grid grid-cols-2 gap-3 text-sm">' +
    '<div><span class="text-slate-400 text-xs block">ID</span><span class="font-medium text-slate-800">#' + m.id + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Data</span><span class="font-medium text-slate-800">' + m.data + '</span></div>' +
    '<div class="col-span-2"><span class="text-slate-400 text-xs block">Descrição</span><span class="font-medium text-slate-800">' + m.descricao + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Tipo</span><span class="font-medium capitalize text-slate-800">' + m.tipo + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Valor</span><span class="font-bold ' + tipoClass + '">' + tipoPrefix + ' ' + m.valor + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Lucro</span><span class="font-medium text-emerald-600">' + m.lucro + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Status</span><span class="font-medium capitalize text-slate-800">' + m.status + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Categoria</span><span class="font-medium text-slate-800">' + m.categoria + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Tipo Operação</span><span class="font-medium text-slate-800">' + m.tipo_operacao + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Empresa</span><span class="font-medium text-slate-800">' + m.empresa + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Banco</span><span class="font-medium text-slate-800">' + m.banco + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Cliente</span><span class="font-medium text-slate-800">' + m.cliente + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Fornecedor</span><span class="font-medium text-slate-800">' + m.fornecedor + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Forma Pagamento</span><span class="font-medium text-slate-800">' + m.forma_pagamento + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Nº Documento</span><span class="font-medium text-slate-800">' + m.numero_documento + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Cobrança</span><span class="font-medium text-slate-800 capitalize">' + m.tipo_cobranca + (m.tipo_cobranca !== 'unica' ? ' (' + m.parcela + ')' : '') + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Conciliado</span><span class="font-medium text-slate-800">' + (m.conciliado ? '✅ Sim' : '❌ Não') + '</span></div>' +
    (m.socio_nome ? '<div><span class="text-slate-400 text-xs block">Sócio</span><span class="font-medium text-purple-700">👤 ' + m.socio_nome + ' (' + m.socio_percentual + '%)</span></div>' : '') +
    '<div class="col-span-2"><span class="text-slate-400 text-xs block">Observações</span><span class="font-medium text-slate-800">' + m.observacoes + '</span></div>' +
    '</div>' +
    '<div class="mt-4 flex justify-end gap-2"><a href="/movimentacoes/' + m.id + '/editar" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm hover:bg-indigo-700">Editar</a>' +
    '<button onclick="closeDetalheModal()" class="px-4 py-2 bg-slate-100 text-slate-600 rounded-lg text-sm hover:bg-slate-200">Fechar</button></div>';
  document.getElementById('detalhe-content').innerHTML = html;
  document.getElementById('detalhe-modal').classList.remove('hidden');
  document.getElementById('detalhe-modal').classList.add('flex');
}

function closeDetalheModal() {
  document.getElementById('detalhe-modal').classList.add('hidden');
  document.getElementById('detalhe-modal').classList.remove('flex');
}

document.getElementById('detalhe-modal').addEventListener('click', function(e) {
  if (e.target === this) closeDetalheModal();
});

function abrirModalTransferencia(movId, contaOrigemId, valor) {
  var form = document.getElementById('form-converter-transferencia');
  form.action = '/movimentacoes/' + movId + '/converter-transferencia';

  // Exibir valor formatado
  var valorNum = parseFloat(valor);
  var valorFmt = 'R$ ' + valorNum.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
  document.getElementById('modal-transf-valor').textContent = valorFmt;

  // Ocultar conta de origem no select de destino
  var select = document.getElementById('modal-transf-conta-destino');
  Array.from(select.options).forEach(function(opt) {
    opt.hidden = opt.value == contaOrigemId;
  });
  select.value = '';

  var modal = document.getElementById('modal-transferencia');
  modal.classList.remove('hidden');
  modal.classList.add('flex');
}

function fecharModalTransferencia() {
  var modal = document.getElementById('modal-transferencia');
  modal.classList.add('hidden');
  modal.classList.remove('flex');
}

document.getElementById('modal-transferencia').addEventListener('click', function(e) {
  if (e.target === this) fecharModalTransferencia();
});
</script>
