<!-- Dados inline para selects -->
<script>
var _categorias = [
  <% @categorias.each do |c| %>
  {id:<%= c[:id] %>,nome:"<%= c[:nome].to_s.gsub('\\','\\\\').gsub('"','\\"') %>",cor:"<%= c[:cor]||'#94a3b8' %>",tipo:"<%= c[:tipo] %>"},
  <% end %>
];
var _clientes = [
  <% @clientes.each do |c| %>
  {id:<%= c[:id] %>,nome:"<%= c[:nome].to_s.gsub('\\','\\\\').gsub('"','\\"') %>"},
  <% end %>
];
var _fornecedores = [
  <% @fornecedores.each do |f| %>
  {id:<%= f[:id] %>,nome:"<%= f[:nome].to_s.gsub('\\','\\\\').gsub('"','\\"') %>"},
  <% end %>
];
var _socios = [
  <% @socios.each do |s| %>
  {id:<%= s[:id] %>,nome:"<%= s[:nome].to_s.gsub('\\','\\\\').gsub('"','\\"') %>",pct:"<%= s[:percentual_participacao] %>"},
  <% end %>
];

// ── estado global ──────────────────────────────────────────────
var _ctx = null;   // contexto do inline ativo

function _fechar() {
  if (!_ctx) return;
  if (_ctx.widget && _ctx.widget.parentNode) _ctx.widget.parentNode.removeChild(_ctx.widget);
  _ctx.cell.querySelectorAll('[data-inline-hide]').forEach(function(el){ el.hidden = false; });
  _ctx = null;
}

// ── SELECT (categoria / parte) ──────────────────────────────────
function abrirInline(cell, tipo, movId) {
  if (_ctx) _fechar();

  var sel = document.createElement('select');
  sel.className = 'text-xs border-2 border-indigo-400 rounded px-1.5 py-1 bg-white shadow focus:outline-none min-w-[150px]';
  sel.appendChild(new Option('— remover —', ''));

  if (tipo === 'categoria') {
    ['receita','despesa'].forEach(function(t) {
      var og = document.createElement('optgroup');
      og.label = t === 'receita' ? 'Receitas' : 'Despesas';
      _categorias.filter(function(c){return c.tipo===t;}).forEach(function(c){
        og.appendChild(new Option(c.nome, c.id));
      });
      sel.appendChild(og);
    });
  } else {
    var ogC = document.createElement('optgroup'); ogC.label = 'Clientes';
    _clientes.forEach(function(c){ ogC.appendChild(new Option(c.nome, 'cli_'+c.id)); });
    var ogF = document.createElement('optgroup'); ogF.label = 'Fornecedores';
    _fornecedores.forEach(function(f){ ogF.appendChild(new Option(f.nome, 'forn_'+f.id)); });
    var ogS = document.createElement('optgroup'); ogS.label = 'Sócios';
    _socios.forEach(function(s){ ogS.appendChild(new Option('👤 '+s.nome+' ('+s.pct+'%)', 'soc_'+s.id)); });
    [ogC,ogF,ogS].forEach(function(og){ sel.appendChild(og); });
  }

  _ctx = {cell:cell, tipo:tipo, movId:movId, widget:sel, kind:'select'};
  cell.querySelectorAll('span').forEach(function(el){ el.setAttribute('data-inline-hide',''); el.hidden=true; });
  cell.appendChild(sel);

  // ── Usar mousedown para capturar a seleção ANTES do blur ──
  sel.addEventListener('mousedown', function(e){
    // Marcar que uma opção foi clicada, para não fechar no blur
    sel._selecting = true;
  });
  sel.addEventListener('change', function(){
    sel._selecting = false;
    _salvarSelect(_ctx);
  });
  sel.addEventListener('keydown', function(e){
    if (e.key === 'Escape') { sel._selecting = false; _fechar(); }
    if (e.key === 'Enter')  { sel._selecting = false; _salvarSelect(_ctx); }
  });
  sel.addEventListener('blur', function(){
    // Só fechar se não está no meio de selecionar uma opção
    if (!sel._selecting) setTimeout(_fechar, 150);
  });

  sel.focus();
}

function _salvarSelect(ctx) {
  var val  = ctx.widget.value;
  var body = {};
  if (ctx.tipo === 'categoria') {
    body.categoria_id = val;
  } else {
    body.cliente_id = ''; body.fornecedor_id = ''; body.socio_id = '';
    if (val.startsWith('cli_'))  body.cliente_id    = val.slice(4);
    if (val.startsWith('forn_')) body.fornecedor_id = val.slice(5);
    if (val.startsWith('soc_'))  body.socio_id      = val.slice(4);
  }
  _quickSave(ctx, body, function(data){ _atualizarCelulaSelect(ctx, data); });
}

function _atualizarCelulaSelect(ctx, data) {
  if (ctx.tipo === 'categoria') {
    var el = ctx.cell.querySelector('.categoria-display-'+ctx.movId);
    if (data.categoria_nome) {
      el.innerHTML = '<span class="w-2 h-2 rounded-full flex-shrink-0" style="background-color:'+data.categoria_cor+'"></span>'
                   + '<span class="text-slate-600 text-xs">'+data.categoria_nome+'</span>';
    } else {
      el.innerHTML = '<span class="text-slate-300 text-xs">+ categoria</span>';
    }
  } else {
    var el = ctx.cell.querySelector('.parte-display-'+ctx.movId);
    if (data.socio_nome) {
      el.innerHTML = '<span class="text-purple-600 font-medium">👤 '+data.socio_nome+' ('+data.socio_percentual+'%)</span>';
    } else if (data.cliente_nome || data.fornecedor_nome) {
      el.textContent = data.cliente_nome || data.fornecedor_nome;
    } else {
      el.innerHTML = '<span class="text-slate-300">+ vincular</span>';
    }
  }
}

// ── INPUT TEXTO (descrição) ─────────────────────────────────────
function abrirInlineTexto(cell, campo, movId) {
  if (_ctx) _fechar();

  var displayEl = cell.querySelector('.'+campo+'-display-'+movId);
  var valorAtual = displayEl ? displayEl.textContent.trim() : '';

  var inp = document.createElement('input');
  inp.type = 'text';
  inp.value = valorAtual;
  inp.className = 'text-sm border-2 border-indigo-400 rounded px-2 py-1 bg-white shadow focus:outline-none w-full min-w-[180px]';

  _ctx = {cell:cell, tipo:campo, movId:movId, widget:inp, kind:'text', displayEl:displayEl};
  if (displayEl) { displayEl.setAttribute('data-inline-hide',''); displayEl.hidden = true; }
  // Inserir antes do displayEl ou no início da célula
  cell.insertBefore(inp, cell.firstChild);

  inp.focus();
  inp.select();

  inp.addEventListener('keydown', function(e){
    if (e.key === 'Enter')  { e.preventDefault(); _salvarTexto(_ctx); }
    if (e.key === 'Escape') { _fechar(); }
  });
  inp.addEventListener('blur', function(){
    // Só salva se o valor mudou
    if (inp.value.trim() !== valorAtual) _salvarTexto(_ctx);
    else _fechar();
  });
}

function _salvarTexto(ctx) {
  var val = ctx.widget.value.trim();
  if (!val) { _fechar(); return; }
  var body = {};
  body[ctx.tipo] = val;
  _quickSave(ctx, body, function(data){
    if (ctx.displayEl) ctx.displayEl.textContent = val;
  });
}

// ── HTTP helper ─────────────────────────────────────────────────
function _quickSave(ctx, body, onSuccess) {
  ctx.widget.disabled = true;
  ctx.widget.style.opacity = '0.5';
  var fd = new FormData();
  Object.keys(body).forEach(function(k){ fd.append(k, body[k]); });
  fetch('/movimentacoes/'+ctx.movId+'/quick-update', {method:'POST', body:fd})
    .then(function(r){ return r.json(); })
    .then(function(data){
      if (data.ok) {
        _fechar();
        onSuccess(data);
        ctx.cell.style.transition = 'background 0.1s';
        ctx.cell.style.background = '#d1fae5';
        setTimeout(function(){ ctx.cell.style.background = ''; }, 700);
      } else { _fechar(); }
    })
    .catch(_fechar);
}

// Fechar ao clicar fora de qualquer inline ativo
document.addEventListener('mousedown', function(e){
  if (_ctx && !_ctx.cell.contains(e.target)) _fechar();
});
</script>

<script>
var movData = {};
<% @movimentacoes.each do |m| %>
movData[<%= m[:id] %>] = {
  id: <%= m[:id] %>,
  tipo: '<%= m[:tipo] %>',
  descricao: '<%= m[:descricao]&.gsub("'", "\\\\'") %>',
  data: '<%= fmt_data(m[:data_movimentacao]) %>',
  valor: '<%= fmt_moeda(m[:valor_bruto]) %>',
  lucro: '<%= m[:lucro] && m[:lucro] > 0 ? fmt_moeda(m[:lucro]) : "-" %>',
  status: '<%= m[:status] %>',
  categoria: '<%= m[:categoria_nome] || "-" %>',
  empresa: '<%= m[:empresa_nome] || "-" %>',
  banco: '<%= m[:banco_nome] || "-" %>',
  cliente: '<%= m[:cliente_nome] || "-" %>',
  fornecedor: '<%= m[:fornecedor_nome] || "-" %>',
  tipo_operacao: '<%= m[:tipo_operacao]&.gsub("_", " ")&.capitalize || "-" %>',
  forma_pagamento: '<%= m[:forma_pagamento]&.gsub("_", " ")&.capitalize || "-" %>',
  numero_documento: '<%= m[:numero_documento] || "-" %>',
  observacoes: '<%= m[:observacoes]&.gsub("'", "\\\\'")&.gsub("\n", " ") || "-" %>',
  conciliado: <%= m[:conciliado] ? 'true' : 'false' %>,
  tipo_cobranca: '<%= m[:tipo_cobranca] || "unica" %>',
  parcela: '<%= m[:parcela_atual] %>/<%= m[:total_parcelas] %>',
  socio_nome: '<%= m[:socio_nome] || "" %>',
  socio_percentual: '<%= m[:socio_percentual] || "" %>'
};
<% end %>

function showDetalheModal(id) {
  var m = movData[id];
  if (!m) return;
  var tipoClass = m.tipo === 'receita' ? 'text-emerald-600' : 'text-red-600';
  var tipoPrefix = m.tipo === 'receita' ? '+' : '-';
  var html = '<div class="grid grid-cols-2 gap-3 text-sm">' +
    '<div><span class="text-slate-400 text-xs block">ID</span><span class="font-medium text-slate-800">#' + m.id + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Data</span><span class="font-medium text-slate-800">' + m.data + '</span></div>' +
    '<div class="col-span-2"><span class="text-slate-400 text-xs block">Descrição</span><span class="font-medium text-slate-800">' + m.descricao + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Tipo</span><span class="font-medium capitalize text-slate-800">' + m.tipo + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Valor</span><span class="font-bold ' + tipoClass + '">' + tipoPrefix + ' ' + m.valor + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Lucro</span><span class="font-medium text-emerald-600">' + m.lucro + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Status</span><span class="font-medium capitalize text-slate-800">' + m.status + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Categoria</span><span class="font-medium text-slate-800">' + m.categoria + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Tipo Operação</span><span class="font-medium text-slate-800">' + m.tipo_operacao + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Empresa</span><span class="font-medium text-slate-800">' + m.empresa + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Banco</span><span class="font-medium text-slate-800">' + m.banco + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Cliente</span><span class="font-medium text-slate-800">' + m.cliente + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Fornecedor</span><span class="font-medium text-slate-800">' + m.fornecedor + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Forma Pagamento</span><span class="font-medium text-slate-800">' + m.forma_pagamento + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Nº Documento</span><span class="font-medium text-slate-800">' + m.numero_documento + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Cobrança</span><span class="font-medium text-slate-800 capitalize">' + m.tipo_cobranca + (m.tipo_cobranca !== 'unica' ? ' (' + m.parcela + ')' : '') + '</span></div>' +
    '<div><span class="text-slate-400 text-xs block">Conciliado</span><span class="font-medium text-slate-800">' + (m.conciliado ? '✅ Sim' : '❌ Não') + '</span></div>' +
    (m.socio_nome ? '<div><span class="text-slate-400 text-xs block">Sócio</span><span class="font-medium text-purple-700">👤 ' + m.socio_nome + ' (' + m.socio_percentual + '%)</span></div>' : '') +
    '<div class="col-span-2"><span class="text-slate-400 text-xs block">Observações</span><span class="font-medium text-slate-800">' + m.observacoes + '</span></div>' +
    '</div>' +
    '<div class="mt-4 flex justify-end gap-2"><a href="/movimentacoes/' + m.id + '/editar" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm hover:bg-indigo-700">Editar</a>' +
    '<button onclick="closeDetalheModal()" class="px-4 py-2 bg-slate-100 text-slate-600 rounded-lg text-sm hover:bg-slate-200">Fechar</button></div>';
  document.getElementById('detalhe-content').innerHTML = html;
  document.getElementById('detalhe-modal').classList.remove('hidden');
  document.getElementById('detalhe-modal').classList.add('flex');
}

function closeDetalheModal() {
  document.getElementById('detalhe-modal').classList.add('hidden');
  document.getElementById('detalhe-modal').classList.remove('flex');
}

document.getElementById('detalhe-modal').addEventListener('click', function(e) {
  if (e.target === this) closeDetalheModal();
});

var _transfMovId = null;
var _transfValor = null;
var _transfContaOrigemId = null;
var _buscaTimer = null;

function abrirModalTransferencia(movId, contaOrigemId, valor) {
  _transfMovId = movId;
  _transfValor = parseFloat(valor);
  _transfContaOrigemId = contaOrigemId;

  document.getElementById('form-converter-transferencia').action = '/movimentacoes/' + movId + '/converter-transferencia';
  document.getElementById('modal-transf-valor').textContent = 'R$ ' + _transfValor.toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2});

  // Ocultar conta de origem no select de criar
  var select = document.getElementById('modal-transf-conta-destino');
  Array.from(select.options).forEach(function(opt) { opt.hidden = opt.value == contaOrigemId; });
  select.value = '';

  // Reset aba vincular
  document.getElementById('busca-entrada').value = '';
  document.getElementById('lista-entradas').innerHTML = '<p class="text-slate-400 text-xs text-center py-6">Digite para buscar receitas disponíveis</p>';
  document.getElementById('entrada-selecionada-id').value = '';
  document.getElementById('entrada-selecionada-info').classList.add('hidden');
  document.getElementById('btn-vincular').disabled = true;
  document.getElementById('vincular-descricao').value = '';

  abaTransf('vincular');

  var modal = document.getElementById('modal-transferencia');
  modal.classList.remove('hidden');
  modal.classList.add('flex');
}

function fecharModalTransferencia() {
  document.getElementById('modal-transferencia').classList.add('hidden');
  document.getElementById('modal-transferencia').classList.remove('flex');
}

function abaTransf(aba) {
  document.getElementById('painel-vincular').classList.toggle('hidden', aba !== 'vincular');
  document.getElementById('painel-criar').classList.toggle('hidden', aba !== 'criar');
  document.getElementById('aba-vincular').className = aba === 'vincular'
    ? 'px-4 py-2.5 text-sm font-medium border-b-2 border-teal-500 text-teal-600 -mb-px transition'
    : 'px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 -mb-px transition';
  document.getElementById('aba-criar').className = aba === 'criar'
    ? 'px-4 py-2.5 text-sm font-medium border-b-2 border-teal-500 text-teal-600 -mb-px transition'
    : 'px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 -mb-px transition';
}

function buscarEntradas(q) {
  clearTimeout(_buscaTimer);
  _buscaTimer = setTimeout(function() {
    document.getElementById('busca-loading').classList.remove('hidden');
    var url = '/movimentacoes/buscar-para-vincular?excluir_id=' + _transfMovId + '&valor=' + _transfValor + '&q=' + encodeURIComponent(q);
    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(items) {
        document.getElementById('busca-loading').classList.add('hidden');
        var lista = document.getElementById('lista-entradas');
        if (!items.length) {
          lista.innerHTML = '<p class="text-slate-400 text-xs text-center py-6">Nenhuma receita encontrada</p>';
          return;
        }
        lista.innerHTML = items.map(function(m) {
          var data = m.data.split('-').reverse().join('/');
          var valor = parseFloat(m.valor).toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2});
          return '<div class="flex items-center justify-between px-3 py-2.5 hover:bg-teal-50 cursor-pointer border-b border-slate-100 last:border-0" onclick="selecionarEntrada('+m.id+', this)">'
            + '<div><p class="text-slate-800 text-xs font-medium truncate max-w-[260px]">'+m.descricao+'</p>'
            + '<p class="text-slate-400 text-xs">'+m.banco+' &middot; '+data+'</p></div>'
            + '<span class="text-emerald-600 font-semibold text-xs whitespace-nowrap ml-2">R$ '+valor+'</span>'
            + '</div>';
        }).join('');
      })
      .catch(function() { document.getElementById('busca-loading').classList.add('hidden'); });
  }, 300);
}

function selecionarEntrada(id, el) {
  document.getElementById('entrada-selecionada-id').value = id;
  var descEl = el.querySelector('p');
  document.getElementById('entrada-selecionada-texto').textContent = '✓ Selecionada: ' + (descEl ? descEl.textContent : '');
  document.getElementById('entrada-selecionada-info').classList.remove('hidden');
  document.getElementById('btn-vincular').disabled = false;
  // Destacar linha
  document.querySelectorAll('#lista-entradas > div').forEach(function(d) { d.classList.remove('bg-teal-100'); });
  el.classList.add('bg-teal-100');
}

function confirmarVincular() {
  var entradaId = document.getElementById('entrada-selecionada-id').value;
  var descricao = document.getElementById('vincular-descricao').value;
  if (!entradaId) return;

  var btn = document.getElementById('btn-vincular');
  btn.disabled = true;
  btn.textContent = 'Vinculando...';

  var fd = new FormData();
  fd.append('entrada_id', entradaId);
  fd.append('descricao', descricao);

  fetch('/movimentacoes/' + _transfMovId + '/vincular-transferencia', { method: 'POST', body: fd })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.ok) {
        fecharModalTransferencia();
        // Flash na página e reload para refletir mudanças de status
        alert(data.message);
        window.location.reload();
      } else {
        alert('Erro: ' + (data.error || 'Tente novamente'));
        btn.disabled = false;
        btn.textContent = 'Vincular as duas';
      }
    })
    .catch(function() {
      alert('Erro de comunicação. Tente novamente.');
      btn.disabled = false;
    });
}

document.getElementById('modal-transferencia').addEventListener('click', function(e) {
  if (e.target === this) fecharModalTransferencia();
});
</script>
