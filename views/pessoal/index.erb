<!-- views/pessoal/index.erb - Finanças pessoais -->

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Minhas Finanças</h1>
    <p class="text-slate-500 text-sm mt-1">Controle pessoal · <%= nome_mes(@mes) %>/<%= @ano %></p>
  </div>
  <a href="/pessoal/nova" class="px-4 py-2.5 bg-violet-600 text-white rounded-lg text-sm font-medium hover:bg-violet-700 transition flex items-center gap-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Novo Lançamento
  </a>
</div>

<!-- Filtros -->
<form method="GET" class="flex items-center gap-3 mb-6">
  <select name="mes" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
    <% meses_select.each do |num, nome| %>
      <option value="<%= num %>" <%= @mes == num ? 'selected' : '' %>><%= nome %></option>
    <% end %>
  </select>
  <select name="ano" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
    <% anos_select.each do |a| %>
      <option value="<%= a %>" <%= @ano == a ? 'selected' : '' %>><%= a %></option>
    <% end %>
  </select>
  <button type="submit" class="px-4 py-2 bg-violet-600 text-white rounded-lg text-sm font-medium hover:bg-violet-700">Filtrar</button>
</form>

<!-- KPIs Pessoais -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
  <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-200">
    <span class="text-xs font-semibold text-slate-500 uppercase">Receitas</span>
    <p class="text-2xl font-bold text-emerald-600 mt-1"><%= fmt_moeda(@resumo[:receitas]) %></p>
  </div>
  <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-200">
    <span class="text-xs font-semibold text-slate-500 uppercase">Despesas</span>
    <p class="text-2xl font-bold text-red-600 mt-1"><%= fmt_moeda(@resumo[:despesas]) %></p>
  </div>
  <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-200">
    <span class="text-xs font-semibold text-slate-500 uppercase">Investimentos</span>
    <p class="text-2xl font-bold text-blue-600 mt-1"><%= fmt_moeda(@resumo[:investimentos]) %></p>
  </div>
  <div class="bg-gradient-to-br from-violet-500 to-purple-600 rounded-xl p-5 shadow-sm">
    <span class="text-xs font-semibold text-violet-200 uppercase">Disponível p/ Investir</span>
    <p class="text-2xl font-bold text-white mt-1"><%= fmt_moeda(@resumo[:disponivel_investir]) %></p>
    <p class="text-xs text-violet-200 mt-1">Saldo: <%= fmt_moeda(@resumo[:saldo]) %></p>
  </div>
</div>

<!-- 🏦 Saldos Bancários Pessoais -->
<div class="mb-8">
  <div class="flex items-center justify-between mb-4">
    <h2 class="font-semibold text-slate-800">🏦 Minhas Contas Bancárias</h2>
    <button onclick="document.getElementById('form-nova-conta').classList.toggle('hidden')" class="px-3 py-1.5 bg-violet-600 text-white rounded-lg text-xs font-medium hover:bg-violet-700 transition">+ Nova Conta</button>
  </div>

  <% if @contas && !@contas.empty? %>
    <% total_patrimonio = @contas.sum { |c| c[:saldo_inicial] || 0 } %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
      <% @contas.each do |c| %>
        <% saldo = c[:saldo_inicial] || 0 %>
        <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-200 hover:shadow-md transition group relative">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg <%= saldo >= 0 ? 'bg-emerald-100' : 'bg-red-100' %> flex items-center justify-center">
              <svg class="w-5 h-5 <%= saldo >= 0 ? 'text-emerald-600' : 'text-red-600' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-slate-800 truncate"><%= c[:banco] %></p>
              <p class="text-xs text-slate-400 truncate"><%= c[:apelido] %> · <%= c[:moeda] || 'BRL' %></p>
            </div>
          </div>
          <p class="text-xl font-bold <%= saldo >= 0 ? 'text-emerald-600' : 'text-red-600' %>"><%= fmt_moeda(saldo, c[:moeda] || 'BRL') %></p>

          <!-- Editar saldo / Excluir -->
          <div class="mt-3 flex items-center gap-2">
            <form action="/pessoal/contas/<%= c[:id] %>/saldo" method="POST" class="flex items-center gap-1 flex-1">
              <input type="hidden" name="_method" value="PUT">
              <input type="text" name="saldo_inicial" value="<%= fmt_valor_input(c[:saldo_inicial]) %>" class="w-full px-2 py-1 border border-slate-200 rounded text-xs moeda-br" placeholder="Saldo">
              <button type="submit" class="px-2 py-1 bg-indigo-600 text-white rounded text-xs hover:bg-indigo-700" title="Salvar">✓</button>
            </form>
            <form action="/pessoal/contas/<%= c[:id] %>" method="POST" onsubmit="return confirm('Remover esta conta?')" class="inline">
              <input type="hidden" name="_method" value="DELETE">
              <button class="p-1 text-slate-400 hover:text-red-600 transition" title="Remover">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </form>
          </div>
        </div>
      <% end %>

      <!-- Total Patrimônio card -->
      <div class="bg-gradient-to-br from-slate-800 to-slate-900 rounded-xl p-5 shadow-sm text-white">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-slate-400 uppercase">Total em Contas</p>
          </div>
        </div>
        <p class="text-2xl font-bold"><%= fmt_moeda(total_patrimonio) %></p>
        <p class="text-xs text-slate-400 mt-1"><%= @contas.size %> conta(s) ativa(s)</p>
      </div>
    </div>
  <% else %>
    <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-200 text-center mb-4">
      <svg class="w-12 h-12 text-slate-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
      </svg>
      <p class="text-slate-400 text-sm mb-2">Nenhuma conta bancária pessoal cadastrada</p>
      <button onclick="document.getElementById('form-nova-conta').classList.remove('hidden')" class="text-sm text-violet-600 hover:text-violet-700 font-medium">+ Cadastrar primeira conta</button>
    </div>
  <% end %>

  <!-- Formulário Nova Conta Bancária Pessoal -->
  <div id="form-nova-conta" class="hidden bg-white rounded-xl shadow-sm border border-slate-200 p-6 mb-4">
    <h3 class="font-semibold text-slate-800 mb-4">Nova Conta Bancária</h3>
    <form action="/pessoal/contas" method="POST">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Banco *</label>
          <select name="banco" required class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
            <optgroup label="Bancos BR">
              <% FinSystem::Config::BANCOS_BR.each do |b| %>
                <option value="<%= b %>"><%= b %></option>
              <% end %>
            </optgroup>
            <optgroup label="Bancos US">
              <% FinSystem::Config::BANCOS_US.each do |b| %>
                <option value="<%= b %>"><%= b %></option>
              <% end %>
            </optgroup>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Apelido</label>
          <input type="text" name="apelido" placeholder="Ex: Nubank Pessoal" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Moeda</label>
          <select name="moeda" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
            <option value="BRL">BRL - Real</option>
            <option value="USD">USD - Dólar</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Saldo Atual</label>
          <input type="text" name="saldo_inicial" placeholder="0,00" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm moeda-br">
        </div>
      </div>
      <div class="flex justify-end gap-3 mt-4">
        <button type="button" onclick="document.getElementById('form-nova-conta').classList.add('hidden')" class="px-4 py-2 text-slate-600 bg-white border border-slate-300 rounded-lg text-sm">Cancelar</button>
        <button type="submit" class="px-4 py-2 bg-violet-600 text-white rounded-lg text-sm font-medium hover:bg-violet-700">Cadastrar Conta</button>
      </div>
    </form>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <!-- Gastos por Categoria -->
  <div class="bg-white rounded-xl shadow-sm border border-slate-200">
    <div class="px-5 py-4 border-b border-slate-100">
      <h2 class="font-semibold text-slate-800">Por Categoria</h2>
    </div>
    <div class="p-5 space-y-2">
      <% @resumo[:por_categoria].each do |cat| %>
        <div class="flex items-center justify-between py-1.5">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full" style="background-color: <%= cat[:cor] %>"></span>
            <span class="text-sm text-slate-700"><%= cat[:categoria] || 'Sem Categoria' %></span>
          </div>
          <span class="text-sm font-medium <%= cat[:tipo] == 'receita' ? 'text-emerald-600' : cat[:tipo] == 'investimento' ? 'text-blue-600' : 'text-red-600' %>">
            <%= fmt_moeda(cat[:total]) %>
          </span>
        </div>
      <% end %>
      <% if @resumo[:por_categoria].empty? %>
        <p class="text-sm text-slate-400 text-center py-4">Sem dados neste período</p>
      <% end %>
    </div>
  </div>

  <!-- Movimentações -->
  <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-slate-200">
    <div class="px-5 py-4 border-b border-slate-100">
      <h2 class="font-semibold text-slate-800">Movimentações do Mês</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50">
            <th class="px-5 py-3">Data</th>
            <th class="px-5 py-3">Descrição</th>
            <th class="px-5 py-3">Categoria</th>
            <th class="px-5 py-3 text-right">Valor</th>
            <th class="px-5 py-3 text-center">Ação</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @movimentacoes.each do |m| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-3 text-slate-600"><%= fmt_data(m[:data_movimentacao]) %></td>
              <td class="px-5 py-3 font-medium text-slate-800"><%= m[:descricao] %></td>
              <td class="px-5 py-3">
                <span class="inline-flex items-center gap-1">
                  <span class="w-2 h-2 rounded-full" style="background-color: <%= m[:categoria_cor] %>"></span>
                  <span class="text-xs text-slate-600"><%= m[:categoria_nome] || '-' %></span>
                </span>
              </td>
              <td class="px-5 py-3 text-right font-bold <%= m[:tipo] == 'receita' ? 'text-emerald-600' : m[:tipo] == 'investimento' ? 'text-blue-600' : 'text-red-600' %>">
                <%= m[:tipo] == 'receita' ? '+' : '-' %> <%= fmt_moeda(m[:valor]) %>
              </td>
              <td class="px-5 py-3 text-center">
                <div class="flex items-center justify-center gap-1">
                  <a href="/pessoal/<%= m[:id] %>/editar" class="p-1.5 text-slate-400 hover:text-indigo-600 transition" title="Editar">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  </a>
                  <form action="/pessoal/<%= m[:id] %>" method="POST" onsubmit="return confirm('Excluir?')" class="inline">
                    <input type="hidden" name="_method" value="DELETE">
                    <button class="p-1.5 text-slate-400 hover:text-red-600 transition" title="Excluir">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <% if @movimentacoes.empty? %>
        <div class="text-center py-12">
          <p class="text-slate-400 text-sm">Nenhum lançamento neste período</p>
        </div>
      <% end %>
      <!-- Paginação -->
      <% if @total_pages > 1 %>
        <div class="px-5 py-3 border-t border-slate-100 flex justify-between items-center bg-slate-50">
          <span class="text-xs text-slate-500">Página <%= @page %> de <%= @total_pages %> (<%= @total_registros %> registros)</span>
          <div class="flex gap-1">
            <% if @page > 1 %>
              <a href="/pessoal?page=<%= @page - 1 %>&mes=<%= @mes %>&ano=<%= @ano %>" class="px-3 py-1 text-xs bg-white border border-slate-300 rounded hover:bg-slate-50">&laquo; Anterior</a>
            <% end %>
            <% if @page < @total_pages %>
              <a href="/pessoal?page=<%= @page + 1 %>&mes=<%= @mes %>&ano=<%= @ano %>" class="px-3 py-1 text-xs bg-white border border-slate-300 rounded hover:bg-slate-50">Próxima &raquo;</a>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Gráfico Evolução Pessoal -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 mb-8">
  <div class="px-5 py-4 border-b border-slate-100">
    <h2 class="font-semibold text-slate-800">Evolução Mensal (Últimos 6 meses)</h2>
  </div>
  <div class="p-5">
    <canvas id="chartPessoal" height="180"></canvas>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const ctx = document.getElementById('chartPessoal');
  if (ctx) {
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: [<%= @evolucao.map { |e| "'#{e[:mes]}'" }.join(',') %>],
        datasets: [
          { label: 'Receitas', data: [<%= @evolucao.map { |e| e[:receitas] }.join(',') %>], backgroundColor: 'rgba(16,185,129,0.7)', borderRadius: 4 },
          { label: 'Despesas', data: [<%= @evolucao.map { |e| e[:despesas] }.join(',') %>], backgroundColor: 'rgba(239,68,68,0.7)', borderRadius: 4 },
          { label: 'Investimentos', data: [<%= @evolucao.map { |e| e[:investimentos] }.join(',') %>], backgroundColor: 'rgba(59,130,246,0.7)', borderRadius: 4 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: 15, font: { size: 11 } } } },
        scales: { y: { beginAtZero: true, ticks: { callback: v => 'R$ ' + v.toLocaleString('pt-BR') } }, x: { grid: { display: false } } }
      }
    });
  }
});
</script>
