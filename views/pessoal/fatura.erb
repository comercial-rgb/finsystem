<!-- views/pessoal/fatura.erb - Detalhe de Fatura Pessoal -->

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">
      Fatura <%= nome_mes(@fatura[:mes_referencia]) %>/<%= @fatura[:ano_referencia] %>
    </h1>
    <p class="text-slate-500 text-sm mt-1">
      <%= @cartao[:banco] %> •••<%= @cartao[:ultimos_digitos] %> · <%= @cartao[:bandeira] %>
    </p>
  </div>
  <a href="/pessoal/cartoes" class="px-4 py-2 text-slate-600 bg-white border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50">&larr; Meus Cartões</a>
</div>

<!-- KPIs -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5">
    <p class="text-xs text-slate-500 uppercase tracking-wide">Total da Fatura</p>
    <p class="text-2xl font-bold text-orange-600 mt-1"><%= fmt_moeda(@fatura[:valor_total]) %></p>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5">
    <p class="text-xs text-slate-500 uppercase tracking-wide">Vencimento</p>
    <p class="text-2xl font-bold text-slate-800 mt-1"><%= fmt_data(@fatura[:data_vencimento]) %></p>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5">
    <p class="text-xs text-slate-500 uppercase tracking-wide">Status</p>
    <p class="text-lg font-bold mt-2"><%= badge_status(@fatura[:status]) %></p>
  </div>
</div>

<!-- Despesas da Fatura -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200">
  <div class="px-5 py-4 border-b border-slate-100">
    <h2 class="font-semibold text-slate-800">Lançamentos da Fatura</h2>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50">
          <th class="px-5 py-3">Data</th>
          <th class="px-5 py-3">Descrição</th>
          <th class="px-5 py-3 text-center">Parcela</th>
          <th class="px-5 py-3 text-right">Valor</th>
          <th class="px-5 py-3 text-center">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @despesas.each do |d| %>
          <tr class="hover:bg-slate-50">
            <td class="px-5 py-3 text-slate-600"><%= fmt_data(d[:data_compra]) %></td>
            <td class="px-5 py-3 font-medium text-slate-800"><%= d[:descricao] %></td>
            <td class="px-5 py-3 text-center">
              <% if d[:total_parcelas].to_i > 1 %>
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-violet-100 text-violet-700">
                  <%= d[:parcela_atual] %>/<%= d[:total_parcelas] %>
                </span>
              <% else %>
                <span class="text-slate-400">À vista</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-right font-bold text-slate-800"><%= fmt_moeda(d[:valor_parcela]) %></td>
            <td class="px-5 py-3 text-center">
              <div class="flex items-center justify-center gap-1">
                <button onclick="abrirEdicaoPessoal(<%= d[:id] %>, '<%= d[:descricao].gsub("'", "\\\\'") %>', '<%= fmt_valor_input(d[:valor_parcela]) %>', '<%= fmt_valor_input(d[:valor_total]) %>')" class="p-1.5 text-slate-400 hover:text-indigo-600 transition" title="Editar">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                </button>
                <form action="/pessoal/cartoes/<%= @cartao[:id] %>/despesas/<%= d[:id] %>" method="POST" class="inline" onsubmit="return confirm('Tem certeza que deseja excluir esta despesa?')">
                  <input type="hidden" name="_method" value="DELETE">
                  <button type="submit" class="p-1.5 text-slate-400 hover:text-red-600 transition" title="Excluir">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @despesas.empty? %>
          <tr><td colspan="5" class="px-5 py-8 text-center text-slate-400">Nenhum lançamento nesta fatura</td></tr>
        <% end %>
      </tbody>
      <% if !@despesas.empty? %>
      <tfoot>
        <tr class="bg-slate-50 font-bold text-slate-800">
          <td class="px-5 py-3" colspan="3">Total</td>
          <td class="px-5 py-3 text-right text-orange-600"><%= fmt_moeda(@fatura[:valor_total]) %></td>
          <td></td>
        </tr>
      </tfoot>
      <% end %>
    </table>
  </div>
</div>

<!-- Modal de Edição Pessoal -->
<div id="modal-editar-pessoal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center">
  <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-bold text-slate-800">Editar Despesa</h3>
      <button onclick="fecharEdicaoPessoal()" class="text-slate-400 hover:text-slate-600">&times;</button>
    </div>
    <form id="form-editar-pessoal" method="POST" class="space-y-4">
      <input type="hidden" name="_method" value="PUT">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Descrição</label>
        <input type="text" name="descricao" id="edit-descricao-pessoal" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Valor da Parcela</label>
          <input type="text" name="valor_parcela" id="edit-valor-parcela-pessoal" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm moeda-br">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Valor Total</label>
          <input type="text" name="valor_total" id="edit-valor-total-pessoal" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm moeda-br">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Status</label>
        <select name="status" id="edit-status-pessoal" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
          <option value="pendente">Pendente</option>
          <option value="paga">Paga</option>
          <option value="cancelada">Cancelada</option>
        </select>
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="fecharEdicaoPessoal()" class="px-4 py-2 text-slate-600 bg-white border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50">Cancelar</button>
        <button type="submit" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">Salvar</button>
      </div>
    </form>
  </div>
</div>

<script>
function abrirEdicaoPessoal(id, descricao, valorParcela, valorTotal) {
  document.getElementById('form-editar-pessoal').action = '/pessoal/cartoes/<%= @cartao[:id] %>/despesas/' + id;
  document.getElementById('edit-descricao-pessoal').value = descricao;
  document.getElementById('edit-valor-parcela-pessoal').value = valorParcela;
  document.getElementById('edit-valor-total-pessoal').value = valorTotal;
  document.getElementById('modal-editar-pessoal').classList.remove('hidden');
}

function fecharEdicaoPessoal() {
  document.getElementById('modal-editar-pessoal').classList.add('hidden');
}

document.getElementById('modal-editar-pessoal').addEventListener('click', function(e) {
  if (e.target === this) fecharEdicaoPessoal();
});
</script>
