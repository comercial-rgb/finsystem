<!-- views/pessoal/cartoes.erb - Cartões de crédito pessoais -->

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Meus Cartões de Crédito</h1>
    <p class="text-slate-500 text-sm mt-1">Controle pessoal de cartões</p>
  </div>
  <a href="/pessoal" class="px-4 py-2 text-slate-600 bg-white border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50">&larr; Minhas Finanças</a>
</div>

<!-- Cards dos Cartões -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
  <% @cartoes.each do |c| %>
    <div class="bg-gradient-to-br from-violet-700 to-purple-900 rounded-2xl p-6 text-white shadow-lg relative overflow-hidden">
      <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-full -mr-10 -mt-10"></div>
      <div class="flex items-center justify-between mb-6">
        <span class="text-xs font-semibold uppercase tracking-wider text-violet-300"><%= c[:banco] %></span>
        <span class="text-lg font-bold"><%= c[:bandeira] %></span>
      </div>
      <div class="mb-4">
        <p class="text-sm text-violet-300">•••• •••• •••• <%= c[:ultimos_digitos] || '****' %></p>
        <p class="text-xs text-violet-400 mt-1"><%= c[:apelido] %></p>
      </div>
      <div class="grid grid-cols-2 gap-3 mb-4">
        <div>
          <p class="text-xs text-violet-300">Fatura Atual</p>
          <p class="text-lg font-bold text-orange-300"><%= fmt_moeda(c[:fatura_atual] ? c[:fatura_atual][:valor_total] : 0) %></p>
        </div>
        <div>
          <p class="text-xs text-violet-300">Limite Disponível</p>
          <p class="text-lg font-bold text-emerald-300"><%= fmt_moeda(c[:limite_total] - c[:gastos_abertos]) %></p>
        </div>
      </div>
      <% pct = c[:limite_total] > 0 ? ((c[:gastos_abertos].to_f / c[:limite_total].to_f) * 100).round : 0 %>
      <div class="w-full bg-violet-600 rounded-full h-2 mb-3">
        <div class="h-2 rounded-full <%= pct > 80 ? 'bg-red-400' : pct > 50 ? 'bg-orange-400' : 'bg-emerald-400' %>" style="width: <%= [pct, 100].min %>%"></div>
      </div>
      <div class="flex items-center justify-between text-xs text-violet-400">
        <span>Fecha dia <%= c[:dia_fechamento] %> · Vence dia <%= c[:dia_vencimento] %></span>
        <form action="/pessoal/cartoes/<%= c[:id] %>" method="POST" onsubmit="return confirm('Remover este cartão?')" class="inline">
          <input type="hidden" name="_method" value="DELETE">
          <button class="text-red-300 hover:text-red-200">Remover</button>
        </form>
      </div>
    </div>
  <% end %>

  <!-- Add card -->
  <div class="border-2 border-dashed border-slate-300 rounded-2xl p-6 flex items-center justify-center min-h-[240px]" id="toggle-novo-pessoal">
    <button onclick="document.getElementById('form-novo-pessoal').classList.toggle('hidden'); this.parentElement.classList.toggle('hidden')" class="text-center text-slate-400 hover:text-violet-600 transition">
      <svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      <p class="font-medium">Novo Cartão</p>
    </button>
  </div>
</div>

<!-- Form Novo Cartão Pessoal -->
<div id="form-novo-pessoal" class="hidden bg-white rounded-xl shadow-sm border border-slate-200 p-6 mb-8">
  <h2 class="font-semibold text-slate-800 mb-4">Cadastrar Cartão Pessoal</h2>
  <form action="/pessoal/cartoes" method="POST">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Bandeira *</label>
        <select name="bandeira" required class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
          <option value="Visa">Visa</option>
          <option value="Mastercard">Mastercard</option>
          <option value="Elo">Elo</option>
          <option value="Amex">American Express</option>
          <option value="Hipercard">Hipercard</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Banco *</label>
        <select name="banco" required class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
          <% (FinSystem::Config::BANCOS_BR).each do |b| %>
            <option value="<%= b %>"><%= b %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Últimos 4 dígitos</label>
        <input type="text" name="ultimos_digitos" maxlength="4" placeholder="1234" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Apelido</label>
        <input type="text" name="apelido" placeholder="Ex: Nubank Pessoal" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Limite Total *</label>
        <input type="text" name="limite_total" required placeholder="0,00" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm moeda-br">
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Fecha dia</label>
          <input type="number" name="dia_fechamento" min="1" max="31" value="1" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Vence dia</label>
          <input type="number" name="dia_vencimento" min="1" max="31" value="10" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
        </div>
      </div>
    </div>
    <div class="flex justify-end gap-3 mt-4">
      <button type="button" onclick="document.getElementById('form-novo-pessoal').classList.add('hidden'); document.getElementById('toggle-novo-pessoal').classList.remove('hidden')" class="px-4 py-2 text-slate-600 bg-white border border-slate-300 rounded-lg text-sm">Cancelar</button>
      <button type="submit" class="px-4 py-2 bg-violet-600 text-white rounded-lg text-sm font-medium hover:bg-violet-700">Cadastrar</button>
    </div>
  </form>
</div>

<!-- Lançar Despesa Pessoal -->
<% if !@cartoes.empty? %>
<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 mb-8">
  <h2 class="font-semibold text-slate-800 mb-4">💳 Lançar Despesa no Cartão</h2>
  <form action="/pessoal/cartoes/<%= @cartoes.first[:id] %>/despesas" method="POST" id="form-desp-pessoal">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Cartão *</label>
        <select name="cartao_id" required class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm" onchange="document.getElementById('form-desp-pessoal').action = '/pessoal/cartoes/' + this.value + '/despesas'">
          <% @cartoes.each do |c| %>
            <option value="<%= c[:id] %>"><%= c[:banco] %> •••<%= c[:ultimos_digitos] %> (<%= c[:apelido] %>)</option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Data *</label>
        <input type="date" name="data_compra" value="<%= hoje %>" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Descrição *</label>
        <input type="text" name="descricao" required placeholder="Ex: Ifood, Amazon" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Valor Total *</label>
        <input type="text" name="valor_total" required placeholder="0,00" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm moeda-br">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Parcelas</label>
        <select name="total_parcelas" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
          <% (1..24).each do |n| %>
            <option value="<%= n %>"><%= n %>x</option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Categoria</label>
        <select name="categoria_id" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
          <option value="">-- Selecione --</option>
          <% @categorias.each do |cat| %>
            <option value="<%= cat[:id] %>"><%= cat[:nome] %></option>
          <% end %>
        </select>
      </div>
    </div>
    <div class="flex justify-end mt-4">
      <button type="submit" class="px-4 py-2 bg-orange-600 text-white rounded-lg text-sm font-medium hover:bg-orange-700">Lançar no Cartão</button>
    </div>
  </form>
</div>
<% end %>

<!-- Próximas Faturas Pessoais -->
<% if !@faturas_proximas.empty? %>
<div class="bg-white rounded-xl shadow-sm border border-slate-200">
  <div class="px-5 py-4 border-b border-slate-100">
    <h2 class="font-semibold text-slate-800">📅 Próximas Faturas</h2>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50">
          <th class="px-5 py-3">Cartão</th>
          <th class="px-5 py-3">Referência</th>
          <th class="px-5 py-3">Vencimento</th>
          <th class="px-5 py-3 text-right">Valor</th>
          <th class="px-5 py-3">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @faturas_proximas.each do |f| %>
          <tr class="hover:bg-slate-50">
            <td class="px-5 py-3 font-medium text-slate-800"><%= f[:banco] %> •••<%= f[:ultimos_digitos] %></td>
            <td class="px-5 py-3 text-slate-600"><%= nome_mes(f[:mes_referencia]) %>/<%= f[:ano_referencia] %></td>
            <td class="px-5 py-3 text-slate-600"><%= fmt_data(f[:data_vencimento]) %></td>
            <td class="px-5 py-3 text-right font-bold text-orange-600"><%= fmt_moeda(f[:valor_total]) %></td>
            <td class="px-5 py-3"><%= badge_status(f[:status]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<% end %>
