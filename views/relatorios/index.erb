<!-- views/relatorios/index.erb - Relatório consolidado -->

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Relatório Consolidado</h1>
    <p class="text-slate-500 text-sm mt-1"><%= nome_mes(@mes) %>/<%= @ano %> · Todas as empresas</p>
  </div>
  <div class="flex items-center gap-3">
    <a href="/relatorios/antecipacoes?mes=<%= @mes %>&ano=<%= @ano %>" class="px-4 py-2 bg-purple-600 text-white rounded-lg text-sm font-medium hover:bg-purple-700">
      ⚡ Relatório Antecipações
    </a>
    <a href="/relatorios/exportar_csv?mes=<%= @mes %>&ano=<%= @ano %>" class="px-4 py-2 bg-slate-600 text-white rounded-lg text-sm font-medium hover:bg-slate-700">
      📥 Exportar CSV
    </a>
  </div>
</div>

<!-- Filtro -->
<form method="GET" class="flex items-center gap-3 mb-6">
  <select name="mes" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
    <% meses_select.each do |num, nome| %>
      <option value="<%= num %>" <%= @mes == num ? 'selected' : '' %>><%= nome %></option>
    <% end %>
  </select>
  <select name="ano" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm">
    <% anos_select.each do |a| %>
      <option value="<%= a %>" <%= @ano == a ? 'selected' : '' %>><%= a %></option>
    <% end %>
  </select>
  <button type="submit" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">Filtrar</button>
</form>

<!-- Consolidado Geral -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
  <div class="bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-xl p-5 shadow-sm text-white">
    <span class="text-xs font-semibold text-emerald-200 uppercase">Total Receitas (Grupo)</span>
    <p class="text-3xl font-bold mt-1"><%= fmt_moeda(@total_geral[:receitas]) %></p>
  </div>
  <div class="bg-gradient-to-br from-red-500 to-red-600 rounded-xl p-5 shadow-sm text-white">
    <span class="text-xs font-semibold text-red-200 uppercase">Total Despesas (Grupo)</span>
    <p class="text-3xl font-bold mt-1"><%= fmt_moeda(@total_geral[:despesas]) %></p>
  </div>
  <div class="bg-gradient-to-br <%= @total_geral[:resultado] >= 0 ? 'from-blue-500 to-blue-600' : 'from-orange-500 to-orange-600' %> rounded-xl p-5 shadow-sm text-white">
    <span class="text-xs font-semibold opacity-80 uppercase">Resultado (Grupo)</span>
    <p class="text-3xl font-bold mt-1"><%= fmt_moeda(@total_geral[:resultado]) %></p>
  </div>
</div>

<!-- Por Empresa -->
<div class="space-y-6">
  <% @resumos.each do |r| %>
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="text-lg"><%= r[:empresa][:pais] == 'BR' ? '🇧🇷' : '🇺🇸' %></span>
          <div>
            <h2 class="font-semibold text-slate-800"><%= r[:empresa][:nome_fantasia] %></h2>
            <p class="text-xs text-slate-400"><%= r[:empresa][:cidade] %>, <%= r[:empresa][:estado] %></p>
          </div>
        </div>
        <a href="/empresas/<%= r[:empresa][:id] %>?mes=<%= @mes %>&ano=<%= @ano %>" class="text-sm text-indigo-600 hover:text-indigo-700 font-medium">Detalhes</a>
      </div>

      <div class="p-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
          <div>
            <span class="text-xs text-slate-500 uppercase">Receitas</span>
            <p class="text-lg font-bold text-emerald-600"><%= fmt_moeda(r[:resumo][:total_receitas]) %></p>
          </div>
          <div>
            <span class="text-xs text-slate-500 uppercase">Despesas</span>
            <p class="text-lg font-bold text-red-600"><%= fmt_moeda(r[:resumo][:total_despesas]) %></p>
          </div>
          <div>
            <span class="text-xs text-slate-500 uppercase">Resultado</span>
            <p class="text-lg font-bold <%= r[:resultado] >= 0 ? 'text-blue-600' : 'text-orange-600' %>"><%= fmt_moeda(r[:resultado]) %></p>
          </div>
          <div>
            <span class="text-xs text-slate-500 uppercase">Movimentações</span>
            <p class="text-lg font-bold text-slate-800"><%= r[:resumo][:qtd_movimentacoes] %></p>
          </div>
        </div>

        <!-- Distribuição de lucro -->
        <% if r[:resultado] > 0 && !r[:distribuicao].empty? %>
          <div class="border-t border-slate-100 pt-4">
            <h3 class="text-xs font-semibold text-slate-500 uppercase mb-2">Distribuição de Lucros</h3>
            <div class="flex flex-wrap gap-3">
              <% r[:distribuicao].each do |d| %>
                <div class="bg-emerald-50 rounded-lg px-4 py-2 border border-emerald-200">
                  <p class="text-xs text-emerald-700"><%= d[:socio][:nome] %> (<%= fmt_percentual(d[:percentual]) %>)</p>
                  <p class="text-sm font-bold text-emerald-800"><%= fmt_moeda(d[:valor]) %></p>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
