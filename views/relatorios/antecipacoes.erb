<!-- views/relatorios/antecipacoes.erb - Relatório de antecipações -->

<div class="flex items-center gap-3 mb-6">
  <a href="/relatorios" class="p-2 text-slate-400 hover:text-slate-600 transition">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  </a>
  <div>
    <h1 class="text-2xl font-bold text-slate-800">⚡ Relatório de Antecipações</h1>
    <p class="text-slate-500 text-sm mt-1"><%= nome_mes(@mes) %>/<%= @ano %></p>
  </div>
</div>

<!-- KPIs -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
  <div class="bg-white rounded-xl p-5 shadow-sm border border-purple-200">
    <span class="text-xs font-semibold text-purple-500 uppercase">Total Antecipado</span>
    <p class="text-2xl font-bold text-purple-700 mt-1"><%= fmt_moeda(@total_antecipado) %></p>
    <p class="text-xs text-slate-400 mt-1">Valor enviado aos fornecedores</p>
  </div>
  <div class="bg-white rounded-xl p-5 shadow-sm border border-emerald-200">
    <span class="text-xs font-semibold text-emerald-500 uppercase">Lucro com Taxas</span>
    <p class="text-2xl font-bold text-emerald-700 mt-1"><%= fmt_moeda(@total_lucro) %></p>
    <p class="text-xs text-slate-400 mt-1">Receita das antecipações</p>
  </div>
  <div class="bg-white rounded-xl p-5 shadow-sm border border-blue-200">
    <span class="text-xs font-semibold text-blue-500 uppercase">Taxa Média</span>
    <% taxa_media = @total_antecipado > 0 ? (@total_lucro.to_f / (@total_antecipado + @total_lucro) * 100) : 0 %>
    <p class="text-2xl font-bold text-blue-700 mt-1"><%= fmt_percentual(taxa_media) %></p>
    <p class="text-xs text-slate-400 mt-1">Sobre o valor original</p>
  </div>
</div>

<!-- Tabela de antecipações -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50">
          <th class="px-5 py-3">Data</th>
          <th class="px-5 py-3">Tipo</th>
          <th class="px-5 py-3">Fornecedor</th>
          <th class="px-5 py-3">Empresa</th>
          <th class="px-5 py-3">Descrição</th>
          <th class="px-5 py-3 text-right">Valor Original</th>
          <th class="px-5 py-3 text-right">Valor</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @antecipacoes.each do |a| %>
          <tr class="hover:bg-slate-50">
            <td class="px-5 py-3 text-slate-600"><%= fmt_data(a[:data_movimentacao]) %></td>
            <td class="px-5 py-3"><%= badge_tipo(a[:tipo]) %></td>
            <td class="px-5 py-3 font-medium text-slate-800"><%= a[:fornecedor_nome] || '-' %></td>
            <td class="px-5 py-3 text-slate-600"><%= a[:empresa_nome] %></td>
            <td class="px-5 py-3 text-slate-600"><%= truncar(a[:descricao], 50) %></td>
            <td class="px-5 py-3 text-right text-slate-500"><%= a[:valor_original_faturamento] ? fmt_moeda(a[:valor_original_faturamento]) : '-' %></td>
            <td class="px-5 py-3 text-right font-bold <%= cor_valor(a[:tipo]) %>">
              <%= prefixo_valor(a[:tipo]) %> <%= fmt_moeda(a[:valor_bruto]) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @antecipacoes.empty? %>
      <div class="text-center py-12">
        <p class="text-slate-400 text-sm">Nenhuma antecipação neste período</p>
      </div>
    <% end %>
  </div>
</div>
