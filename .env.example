# ========================================
# FinSystem - Variáveis de Ambiente
# ========================================
# Copie para .env e preencha os valores
# NÃO committar o .env no Git!

# Ambiente: development | production
RACK_ENV=development

# Banco de dados
# Development: usa SQLite automaticamente (não precisa configurar)
# Production: OBRIGATÓRIO usar PostgreSQL via DATABASE_URL
# DATABASE_URL=postgres://user:password@host:5432/finsystem_db

# Segurança - OBRIGATÓRIO trocar em produção!
SESSION_SECRET=troque_por_uma_chave_aleatoria_use_securerandom_hex_64

# Servidor
PORT=4567
WEB_CONCURRENCY=2
RAILS_MAX_THREADS=5

# Domínio (em produção)
# APP_DOMAIN=administracao.frotainstasolutions.com.br
